---
/**
 * src/components/HomeTemplate.astro — Unified Home Layout
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { contact } from '../data/contact.js';
import { pillarServices } from '../data/services.js';
import { primaryLocations } from '../data/locations.js';
import { generateTopicFaqs } from '../data/faqs.js';
import { useTranslations } from '../i18n/ui.js';
import SpeechReader from './SpeechReader.astro';

interface Props {
  lang?: string;
  title?: string;
  description?: string;
}

const { lang = 'en', title, description } = Astro.props;
const t = useTranslations(lang);

const pageTitle = title || "EWaste Kochi | Free Pickup · ₹75K iPhone Buyback · NIST ITAD Kochi — Kerala #1 Certified";
const pageDesc = description || "Kerala's #1 KSPCB-authorized ITAD & e-waste recycling in Kochi. Free pickup for 10+ units. MacBook buyback up to ₹65K · iPhone up to ₹75K. NIST 800-88 data destruction. Certificate of Destruction every job. Serving Infopark, Kakkanad, Ernakulam — same day.";

const homeFaqs = generateTopicFaqs("EWaste Kochi");

const organizationSchema = {
  '@type': 'LocalBusiness',
  name: 'EWaste Kochi',
  description: 'Certified E-Waste Recycling & ITAD Services in Kerala',
  areaServed: 'Kerala',
  knowsAbout: [
    'Electronics Recycling',
    'IT Asset Disposition',
    'Data Destruction',
    'Hazardous Waste Management',
    'Circular Economy'
  ]
};

const breadcrumbs = [
  { name: 'Home', url: '/' }
];

const l = (path: string) => lang === 'en' ? path : `/${lang}${path}`;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  faqs={homeFaqs}
  schema={organizationSchema}
  breadcrumbs={breadcrumbs}
>
  <div id="topbar">
    <div id="ticker">
      <span class="tb-item">♻️ Certified Zero-Landfill Electronics Recycling — Kochi</span>
      <span class="tb-item">🔒 NIST/DoD Data Destruction Every Device</span>
      <span class="tb-item">🏭 KSPCB & CPCB Authorized Facility</span>
      <span class="tb-item">🚚 Free Pickup — Kochi & Ernakulam</span>
      <span class="tb-item">⚡ Same-Day Collection — Infopark & Smart City</span>
      <span class="tb-item">🥇 Kerala's #1 Electronics Recycler since 2018</span>
      <span class="tb-item">📞 24/7 Service — +91-75005-55454</span>
      <!-- loop copy -->
      <span class="tb-item">♻️ Certified Zero-Landfill Electronics Recycling — Kochi</span>
      <span class="tb-item">🔒 NIST/DoD Data Destruction Every Device</span>
      <span class="tb-item">🏭 KSPCB & CPCB Authorized Facility</span>
      <span class="tb-item">🚚 Free Pickup — Kochi & Ernakulam</span>
    </div>
  </div>

  <Navbar currentPath={l("/")} />

  <main id="main-content">
    <div class="wrap" style="margin-top: 20px;">
       <SpeechReader targetSelector="#main-content" />
    </div>
    <!-- MASTER HERO -->
    <section class="hero" style="min-height:90vh;display:flex;align-items:center;background:linear-gradient(135deg, #060809 0%, #0a0f14 100%); position:relative; overflow:hidden;">
      <div style="position:absolute; inset:0; background:radial-gradient(circle at 70% 30%, rgba(245,166,35,0.08), transparent); pointer-events:none;"></div>
      <div class="wrap">
        <div class="hero-inner" style="display:grid;grid-template-columns:1.2fr 0.8fr;gap:60px;align-items:center; position:relative; z-index:2;">
          <div>
            <div class="hero-badge" style="background:rgba(245,166,35,0.1);color:var(--amber);padding:8px 20px;border-radius:30px;display:inline-block;font-size:0.7rem;font-weight:800;letter-spacing:0.15em;margin-bottom:20px;border:1px solid rgba(245,166,35,0.2)">
              {t('home.hero_badge')}
            </div>
            <h1 style="font-size:clamp(3rem, 6vw, 4.5rem);line-height:0.95;margin-bottom:25px;letter-spacing:-0.04em">
              Certified <span style="color:var(--amber)">E-Waste</span> <br/>& ITAD <span style="color:var(--white)">Kochi</span>
            </h1>
            <p style="font-size:1.2rem;color:var(--text);max-width:640px;line-height:1.6;margin-bottom:40px;font-family:var(--serif);font-style:italic">
              {t('home.hero_p')}
            </p>
            <div class="hero-ctas" style="display:flex;gap:15px">
              <a href={l("/contact/")} class="btn btn-primary btn-lg">{t('home.pickup_btn')}</a>
              <a href={contact.phoneLink} class="btn btn-outline btn-lg">{t('nav.call')}</a>
            </div>
            
            <div class="trust-stats" style="display:flex;gap:40px;margin-top:50px;border-top:1px solid var(--border);padding-top:30px">
              <div>
                <span style="display:block;font-size:1.8rem;font-weight:800;color:var(--white)">2.4K+</span>
                <span style="font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em">Tonnes Recycled</span>
              </div>
              <div>
                <span style="display:block;font-size:1.8rem;font-weight:800;color:var(--white)">50K+</span>
                <span style="font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em">Devices Safe-wiped</span>
              </div>
              <div>
                <span style="display:block;font-size:1.8rem;font-weight:800;color:var(--white)">569</span>
                <span style="font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em">Pickzones Active</span>
              </div>
            </div>
          </div>
          
          <div class="hero-visual" style="position:relative">
             <div style="background:var(--card-wiki);border:1px solid var(--border-wiki);border-top:2px solid var(--amber);padding:40px;border-radius:30px;box-shadow:0 30px 60px rgba(0,0,0,0.5)" role="figure" aria-label="Compliance Dashboard">
                <div style="font-size:0.75rem;color:var(--amber);font-weight:800;margin-bottom:20px;text-transform:uppercase">Compliance Dashboard</div>
                <div style="margin-bottom:20px">
                   <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:0.85rem"><span>NIST Data Wiping</span><span style="color:var(--amber)">100%</span></div>
                   <div style="height:6px;background:var(--border-wiki);border-radius:10px"><div style="width:100%;height:6px;background:var(--amber);border-radius:10px"></div></div>
                </div>
                <div style="margin-bottom:20px">
                   <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:0.85rem"><span>Material Recovery</span><span style="color:var(--amber)">98.2%</span></div>
                   <div style="height:6px;background:var(--border-wiki);border-radius:10px"><div style="width:98%;height:6px;background:var(--amber);border-radius:10px"></div></div>
                </div>
                <div style="margin-bottom:20px">
                   <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:0.85rem"><span>Zero Landfill Rate</span><span style="color:var(--amber)">100%</span></div>
                   <div style="height:6px;background:var(--border-wiki);border-radius:10px"><div style="width:100%;height:6px;background:var(--amber);border-radius:10px"></div></div>
                </div>
                <div style="padding-top:10px;text-align:center">
                   <span style="display:block;font-size:2rem;font-weight:800;color:var(--white);letter-spacing:-0.03em">KSPCB Certified</span>
                   <span style="font-size:0.7rem;color:var(--muted)">Verified Recycler #KL/EW/628</span>
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- THE THREE PILLARS (Authority Gateways) -->
    <section class="section-alt">
      <div class="wrap">
        <div class="text-center" style="margin-bottom:60px">
          <h2 class="sec-title">The Three <em>Pillars</em> of Authority</h2>
          <p class="sec-sub">Our high-authority encyclopedias covering every aspect of hardware retirement in Kerala.</p>
        </div>

        <div class="pillar-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:30px">
          <a href="/ewaste/" class="pillar-box" style="background:var(--card);border:1px solid var(--border);padding:40px;border-radius:30px;transition:0.3s">
            <h3 style="color:var(--green);margin-bottom:15px">E-Waste Encyclopedia</h3>
            <p style="font-size:0.9rem;margin-bottom:25px;color:var(--text)">20,000+ words on e-waste laws, toxic chemistry, and material recovery protocols.</p>
            <span style="font-size:0.75rem;font-weight:800;color:var(--green)">ENTRANCE →</span>
          </a>
          <a href="/itad/" class="pillar-box" style="background:var(--card);border:1px solid var(--border);padding:40px;border-radius:30px;transition:0.3s">
            <h3 style="color:var(--blue);margin-bottom:15px">ITAD Center</h3>
            <p style="font-size:0.9rem;margin-bottom:25px;color:var(--text)">Certified IT asset disposition, NIST data destruction, and corporate decommissioning manuals.</p>
            <span style="font-size:0.75rem;font-weight:800;color:var(--blue)">ENTRANCE →</span>
          </a>
          <a href="/recycling/" class="pillar-box" style="background:var(--card);border:1px solid var(--border);padding:40px;border-radius:30px;transition:0.3s">
            <h3 style="color:var(--amber);margin-bottom:15px">Recycling Tech</h3>
            <p style="font-size:0.9rem;margin-bottom:25px;color:var(--text)">Deep dive into urban mining, shredding technology, and zero-landfill processing mechanics.</p>
            <span style="font-size:0.75rem;font-weight:800;color:var(--amber)">ENTRANCE →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- PROGRAMMATIC SERVICE CLUSTER -->
    <section class="section">
      <div class="wrap">
        <div class="text-center" style="margin-bottom:60px">
           <h2 class="sec-title">Certified <em>Industrial</em> Solutions</h2>
           <p class="sec-sub">Specialized recycling and destruction services for every enterprise vertical.</p>
        </div>
        <div class="svc-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
           {pillarServices.map(svc => (
             <a href={`/services/${svc.slug}/`} class="svc-mini-card" style="background:var(--card);padding:25px;border:1px solid var(--border);border-radius:15px;transition:0.2s">
                <div style="font-size:1.5rem;margin-bottom:10px">{svc.icon}</div>
                <h4 style="font-size:0.95rem;margin-bottom:8px">{svc.name}</h4>
                <p style="font-size:0.75rem;color:var(--muted);line-height:1.4">{svc.tagline}</p>
             </a>
           ))}
        </div>
        <div class="text-center" style="margin-top:50px">
           <a href={l("/services/")} class="btn btn-outline">Explore All 17 Specializations →</a>
        </div>
      </div>
    </section>

    <!-- FAQ KNOWLEDGE BASE -->
    <section class="section-alt">
      <div class="wrap">
         <div class="text-center" style="margin-bottom:60px">
            <h2 class="sec-title">The <em>Common</em> Knowledge Base</h2>
            <p class="sec-sub">Mastering the most frequent queries regarding electronic waste in Kerala.</p>
         </div>
         <div class="faq-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
            {homeFaqs.slice(0, 30).map(f => (
              <div class="faq-card" style="background:var(--card);border:1px solid var(--border);padding:25px;border-radius:15px">
                 <h4 style="font-size:0.85rem;margin-bottom:10px;color:var(--white);line-height:1.4">Q: {f.q}</h4>
                 <p style="font-size:0.78rem;color:var(--muted);line-height:1.8">A: {f.a}</p>
              </div>
            ))}
         </div>
      </div>
    </section>

    <!-- GEOGRAPHIC REACH -->
    <section class="section">
       <div class="wrap">
         <div class="text-center" style="margin-bottom:50px">
            <h2 class="sec-title">569 Local <em>Authority</em> Zones</h2>
            <p class="sec-sub">Free corporate collection and localized compliance across every district in Kerala.</p>
         </div>
         <div class="loc-grid" style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center">
            {primaryLocations.map(loc => (
              <a href={`/locations/${loc.slug}/`} class="loc-chip" style="padding:10px 20px;border:1px solid var(--border);border-radius:40px;font-size:0.8rem;font-weight:700;transition:0.3s">
                {loc.name} →
              </a>
            ))}
            <a href={l("/locations/")} class="btn btn-primary" style="padding:10px 20px;color:#000;border-radius:40px;font-size:0.8rem;font-weight:800">VIEW ALL 569 ZONES</a>
         </div>
       </div>
    </section>

    <!-- GSC QUICK WINS — SELL ELECTRONICS + CASHIFY COMPARISON -->
    <section class="section-alt">
      <div class="wrap">
        <div class="text-center" style="margin-bottom:40px">
          <div class="sec-eyebrow">Best Prices in Kerala</div>
          <h2 class="sec-title">Sell Your Old <em>Electronics</em> in Kochi</h2>
          <p class="sec-sub">Better than Cashify. Instant payment. Free pickup for 10+ items. Data destruction included.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:40px">
          {[
            {device:'MacBook Pro M2/M3',price:'₹65,000',sub:'2021–2024 · Any condition'},
            {device:'iPhone 15 Pro Max',price:'₹75,000',sub:'256GB+ · Working'},
            {device:'Dell/HP i7 Laptop',price:'₹18,000',sub:'2020+ · 16GB RAM'},
            {device:'Samsung S24 Ultra',price:'₹50,000',sub:'Excellent condition'},
            {device:'Server (Dell/HP)',price:'₹45,000',sub:'Rack unit · Xeon'},
            {device:'MacBook Air M2',price:'₹45,000',sub:'2022–2024'},
          ].map(item => (
            <div style="background:var(--card);border:1px solid var(--border);border-radius:15px;padding:25px;text-align:center">
              <div style="font-size:.78rem;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.05em">{item.device}</div>
              <div style="font-size:2rem;font-weight:800;color:var(--green);letter-spacing:-.04em">{item.price}</div>
              <div style="font-size:.75rem;color:var(--muted);margin-top:4px">{item.sub}</div>
            </div>
          ))}
        </div>
        <div style="text-align:center;display:flex;gap:15px;justify-content:center;flex-wrap:wrap">
          <a href="/sell-electronics-kochi/" class="btn btn-primary btn-lg">💰 Get Instant Quote →</a>
          <a href="/cashify-vs-ewastekochi/" class="btn btn-outline btn-lg">vs Cashify — Who Pays More?</a>
        </div>
      </div>
    </section>

    <!-- E-WASTE COLLECTION KOCHI (GSC: pos 8.3, 23 impressions) -->
    <section class="section">
      <div class="wrap">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center">
          <div>
            <div class="sec-eyebrow">Free E-Waste Collection</div>
            <h2 class="sec-title">E-Waste <em>Collection</em> in Kochi — Scheduled & Free</h2>
            <p style="color:var(--text);line-height:1.75;margin-bottom:30px">Need e-waste collection in Kochi? EWaste Kochi picks up from your office, home or factory anywhere in Ernakulam district. Free for 10+ devices. Same-day slots available for Infopark, Kakkanad and Smart City.</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:30px">
              {['Free for 10+ devices — Ernakulam district','Same-day priority for Infopark & Smart City','GPS-tracked secure transport','KSPCB manifest provided at pickup','Certificate of Destruction within 24 hours'].map(item => (
                <li style="display:flex;align-items:center;gap:10px;font-size:.9rem">
                  <span style="color:var(--green);font-weight:700">✓</span>
                  <span style="color:var(--text)">{item}</span>
                </li>
              ))}
            </ul>
            <a href="/contact/" class="btn btn-primary">📦 Book Collection Now →</a>
          </div>
          <div style="background:var(--card);border:1px solid var(--border);border-radius:20px;padding:35px">
            <div style="font-size:.75rem;color:var(--green);font-weight:800;margin-bottom:20px;text-transform:uppercase">Pickup Pricing — Ernakulam</div>
            <table style="width:100%;border-collapse:collapse;font-size:.88rem">
              <tr style="border-bottom:1px solid var(--border)"><td style="padding:10px 0;color:var(--text)">50+ units — corporate</td><td style="padding:10px 0;text-align:right;color:var(--green);font-weight:800">FREE</td></tr>
              <tr style="border-bottom:1px solid var(--border)"><td style="padding:10px 0;color:var(--text)">10–49 units</td><td style="padding:10px 0;text-align:right;color:var(--green);font-weight:800">FREE</td></tr>
              <tr style="border-bottom:1px solid var(--border)"><td style="padding:10px 0;color:var(--text)">1–9 units (residential)</td><td style="padding:10px 0;text-align:right;color:var(--muted)">₹99</td></tr>
              <tr><td style="padding:10px 0;color:var(--text)">Walk-in drop-off</td><td style="padding:10px 0;text-align:right;color:var(--green);font-weight:800">FREE</td></tr>
            </table>
            <a href="https://wa.me/917500555454?text=Hi%2C+I+need+ewaste+collection+in+Kochi" target="_blank" rel="noopener" class="btn btn-wa" style="width:100%;justify-content:center;margin-top:20px">💬 WhatsApp to Schedule</a>
          </div>
        </div>
      </div>
    <!-- PICKUP CALCULATOR (Phase 4 CRO Boost) -->
    <section class="section-alt">
      <div class="wrap" style="max-width:800px">
        <div style="background:var(--card);border:2px solid var(--green);border-radius:24px;padding:40px;text-align:center">
          <h3 style="color:var(--white);margin-bottom:10px">Are you eligible for <em>Free Pickup</em>?</h3>
          <p style="font-size:0.9rem;color:var(--muted);margin-bottom:30px">Enter your approximate item count to check eligibility in Ernakulam.</p>
          
          <div style="display:flex;gap:15px;justify-content:center;margin-bottom:20px">
            <input type="number" id="item-count" placeholder="Number of devices..." style="background:var(--bg);border:1px solid var(--border);padding:15px;border-radius:12px;color:var(--white);width:100%;max-width:200px">
            <button id="calc-btn" class="btn btn-primary" style="padding:0 30px">Check Now</button>
          </div>
          
          <div id="calc-result" style="min-height:60px;display:flex;align-items:center;justify-content:center">
            <p style="color:var(--muted);font-size:0.85rem">Enter a number to see your savings.</p>
          </div>
        </div>
      </div>
    </section>

    <script is:inline>
      const input = document.getElementById('item-count');
      const btn = document.getElementById('calc-btn');
      const result = document.getElementById('calc-result');

      btn?.addEventListener('click', () => {
        const count = parseInt(input.value);
        if(!count || count < 1) {
          result.innerHTML = '<p style="color:var(--amber)">Please enter a valid count.</p>';
          return;
        }

        if(count >= 10) {
          result.innerHTML = `
            <div style="color:var(--green);font-weight:800">
              <p>🎉 YOU ARE ELIGIBLE FOR 100% FREE PICKUP!</p>
              <p style="font-size:0.8rem;color:var(--white)">Estimated Savings: ₹499 - ₹1,499</p>
              <a href="https://wa.me/917500555454?text=Hi, my count is ${count}. I am eligible for FREE pickup in Kochi." target="_blank" class="btn btn-wa" style="margin-top:15px;display:inline-flex">Book Now →</a>
            </div>
          `;
        } else {
          result.innerHTML = `
            <div style="color:var(--white)">
              <p>Standard Pickup: ₹99 for ${count} devices.</p>
              <p style="font-size:0.8rem;color:var(--muted)">Pro Tip: Add ${10-count} more items to get FREE pickup!</p>
              <a href="https://wa.me/917500555454?text=Hi, I have ${count} items. Need pickup in Ernakulam." target="_blank" class="btn btn-wa" style="margin-top:15px;display:inline-flex">Book Pickup →</a>
            </div>
          `;
        }
      });
    </script>

  </main>

  <Footer />
</BaseLayout>

<style>
  .pillar-box:hover { transform: translateY(-8px); border-color: inherit; }
  .svc-mini-card:hover { border-color: var(--white); transform: scale(1.02); }
  .loc-chip:hover { border-color: var(--green); color: var(--green); }
</style>
