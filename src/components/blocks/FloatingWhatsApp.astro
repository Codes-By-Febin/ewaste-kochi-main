---
// FloatingWhatsApp.astro - Floating WhatsApp button with multiple contact options
interface Props {
  phone?: string;
  message?: string;
  position?: 'bottom-right' | 'bottom-left' | 'bottom-center';
  showTooltip?: boolean;
  tooltipText?: string;
  pulse?: boolean;
}

const {
  phone = "919876543210",
  message = "Hi! I need help with e-waste recycling.",
  position = 'bottom-right',
  showTooltip = true,
  tooltipText = "Chat with us on WhatsApp",
  pulse = true
} = Astro.props;

const positionClasses = {
  'bottom-right': 'bottom-6 right-6',
  'bottom-left': 'bottom-6 left-6',
  'bottom-center': 'bottom-6 left-1/2 transform -translate-x-1/2'
};
---

<div class={`floating-whatsapp ${positionClasses[position]} ${pulse ? 'pulse-animation' : ''}`} id="floatingWhatsApp">
  {showTooltip && (
    <div class="whatsapp-tooltip" id="whatsappTooltip">
      <span>{tooltipText}</span>
      <div class="tooltip-arrow"></div>
    </div>
  )}
  
  <div class="whatsapp-container">
    <a 
      href={`https://wa.me/${phone}?text=${encodeURIComponent(message)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-button"
      aria-label="Chat on WhatsApp"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.1-.298.149-.447.024-.149-.124-.562-.542-1.068-1.043-.506-.501-.847-.848-1.021-.996-.173-.149-.347-.074-.471.025-.124.099-.472.446-.645.595-.173.149-.347.149-.644 0-.297-.149-1.255-.867-2.39-1.475-1.135-.607-1.904-.467-2.103-.347-.199.12-.77.595-.77 1.392 0 .796.579 1.564 1.058 2.09.479.525 1.033 1.364 1.841 1.841.808.477 1.366.396 1.841.396.475 0 1.364-.149 2.103-.595.739-.446 1.135-1.043 1.364-1.392.229-.349.229-.695.149-.844-.08-.149-.322-.247-.645-.396z"/>
        <path d="M20.52 3.449C18.247 1.244 15.222 0 12 0 8.778 0 5.753 1.244 3.48 3.449 1.207 5.654 0 8.615 0 11.75c0 2.036.614 3.994 1.777 5.673L.057 24l6.858-1.891C8.517 22.682 10.222 23 12 23c3.222 0 6.247-1.244 8.52-3.449 2.273-2.205 3.48-5.166 3.48-8.301 0-3.135-1.207-6.096-3.48-8.301zM12 20.947c-1.604 0-3.168-.472-4.508-1.364l-.322-.199-3.338.876.89-3.25-.199-.323C3.248 14.936 2.77 13.327 2.77 11.75c0-4.817 3.965-8.747 8.83-8.747 2.359 0 4.577.916 6.247 2.58 1.67 1.664 2.59 3.877 2.59 6.194 0 4.817-3.965 8.747-8.83 8.747z"/>
      </svg>
    </a>
    
    <div class="quick-actions" id="quickActions">
      <button 
        class="quick-action-btn call-btn"
        onclick="window.location.href='tel:+919876543210'"
        aria-label="Call us"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
        </svg>
        <span>Call</span>
      </button>
      
      <button 
        class="quick-action-btn quote-btn"
        onclick="openQuickQuote()"
        aria-label="Get quick quote"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 14h-3v3h-2v-3H8v-2h3v-3h2v3h3v2zm-3-7V3.5L18.5 9H13z"/>
        </svg>
        <span>Quote</span>
      </button>
    </div>
  </div>
</div>

<style>
  .floating-whatsapp {
    position: fixed;
    z-index: 1000;
  }

  .whatsapp-container {
    position: relative;
  }

  .whatsapp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #25d366, #1fb855);
    border-radius: 50%;
    color: white;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 3px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .whatsapp-button:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 30px rgba(37, 211, 102, 0.6);
  }

  .pulse-animation .whatsapp-button {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.7);
    }
    70% {
      box-shadow: 0 0 0 20px rgba(37, 211, 102, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0);
    }
  }

  .whatsapp-tooltip {
    position: absolute;
    bottom: 70px;
    right: 0;
    background: var(--glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 16px;
    white-space: nowrap;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .whatsapp-tooltip.show {
    opacity: 1;
    transform: translateY(0);
  }

  .tooltip-arrow {
    position: absolute;
    bottom: -6px;
    right: 20px;
    width: 12px;
    height: 12px;
    background: var(--glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .quick-actions {
    position: absolute;
    bottom: 70px;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .quick-actions.show {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .quick-action-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 16px;
    color: var(--text);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 140px;
    box-shadow: var(--shadow);
  }

  .quick-action-btn:hover {
    background: var(--glass-hover);
    border-color: var(--primary);
    transform: translateX(-4px);
    box-shadow: var(--shadow-lg);
  }

  .call-btn:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .quote-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  @media (max-width: 768px) {
    .whatsapp-button {
      width: 56px;
      height: 56px;
    }

    .quick-action-btn {
      min-width: 120px;
      padding: 10px 14px;
      font-size: 0.8rem;
    }

    .whatsapp-tooltip {
      font-size: 0.8rem;
      padding: 10px 14px;
    }
  }
</style>

<script>
  let isExpanded = false;
  let tooltipTimeout;

  // Show tooltip on page load
  document.addEventListener('DOMContentLoaded', () => {
    const tooltip = document.getElementById('whatsappTooltip');
    if (tooltip) {
      setTimeout(() => {
        tooltip.classList.add('show');
        tooltipTimeout = setTimeout(() => {
          tooltip.classList.remove('show');
        }, 5000);
      }, 2000);
    }
  });

  // Toggle quick actions
  document.querySelector('.whatsapp-button')?.addEventListener('click', (e) => {
    e.preventDefault();
    const quickActions = document.getElementById('quickActions');
    const tooltip = document.getElementById('whatsappTooltip');
    
    if (tooltip) {
      tooltip.classList.remove('show');
      clearTimeout(tooltipTimeout);
    }
    
    isExpanded = !isExpanded;
    quickActions.classList.toggle('show', isExpanded);
    
    if (isExpanded) {
      // Open WhatsApp after a delay if user doesn't click other actions
      setTimeout(() => {
        if (isExpanded) {
          window.open(e.target.closest('a').href, '_blank');
          quickActions.classList.remove('show');
          isExpanded = false;
        }
      }, 3000);
    }
  });

  // Quick quote function
  function openQuickQuote() {
    // This would open a modal or navigate to quote page
    window.location.href = '/quote';
  }

  // Close quick actions when clicking outside
  document.addEventListener('click', (e) => {
    const container = document.querySelector('.whatsapp-container');
    if (!container.contains(e.target)) {
      document.getElementById('quickActions')?.classList.remove('show');
      isExpanded = false;
    }
  });
</script>
