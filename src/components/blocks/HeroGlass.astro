---
// HeroGlass.astro - Premium glassmorphism hero section
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  primaryCTA?: { text: string; url: string };
  secondaryCTA?: { text: string; url: string };
  backgroundImage?: string;
  showTrustBadges?: boolean;
}

const {
  title = "Certified E-Waste Recycling in Kochi",
  subtitle = "Environmental Authority & Digital Trust",
  description = "Kerala's leading certified e-waste management company. Secure data destruction, responsible recycling, and free pickup services.",
  primaryCTA = { text: "Get Free Pickup", url: "tel:+919876543210" },
  secondaryCTA = { text: "WhatsApp Us", url: "https://wa.me/919876543210" },
  backgroundImage = "/img/ewaste-guide-hero.webp",
  showTrustBadges = true
} = Astro.props;
---

<section class="hero-glass">
  <div class="hero-background">
    <div class="hero-overlay"></div>
    {backgroundImage && <img src={backgroundImage} alt="" class="hero-image" />}
  </div>
  
  <div class="wrap">
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="badge-g">🏆 Certified</span>
        <span class="badge-b">🔒 Data Secure</span>
        <span class="badge-a">🌱 Eco-Friendly</span>
      </div>
      
      <h1 class="hero-title">
        {title}
      </h1>
      
      <p class="hero-subtitle">
        {subtitle}
      </p>
      
      <p class="hero-description">
        {description}
      </p>
      
      <div class="hero-actions">
        <a href={primaryCTA.url} class="btn btn-primary btn-lg">
          <span>📞</span>
          {primaryCTA.text}
        </a>
        <a href={secondaryCTA.url} class="btn btn-wa btn-lg">
          <span>💬</span>
          {secondaryCTA.text}
        </a>
      </div>
      
      {showTrustBadges && (
        <div class="trust-indicators">
          <div class="trust-item">
            <span class="trust-number">5000+</span>
            <span class="trust-label">Devices Recycled</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">98%</span>
            <span class="trust-label">Customer Satisfaction</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">24/7</span>
            <span class="trust-label">Pickup Available</span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-glass {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  
  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(11, 15, 20, 0.9) 0%,
      rgba(11, 15, 20, 0.7) 50%,
      rgba(0, 208, 132, 0.1) 100%
    );
    backdrop-filter: blur(2px);
  }
  
  .hero-content {
    max-width: 800px;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  
  .hero-eyebrow {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
    background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }
  
  .hero-subtitle {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 20px;
    opacity: 0.9;
  }
  
  .hero-description {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }
  
  .trust-indicators {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 32px;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .trust-item {
    text-align: center;
    padding: 24px;
    background: var(--glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .trust-item:hover {
    transform: translateY(-4px);
    background: var(--glass-hover);
    border-color: var(--primary);
    box-shadow: 0 8px 32px rgba(0, 208, 132, 0.2);
  }
  
  .trust-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 8px;
  }
  
  .trust-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  
  @media (max-width: 768px) {
    .hero-glass {
      min-height: 80vh;
      padding: 80px 0;
    }
    
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    
    .trust-indicators {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
