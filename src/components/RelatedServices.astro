---
import { serviceMappings, blogTagMappings } from '../data/taxonomy';

export interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;

// Determine services based on tags
const serviceIds = new Set<string>();
tags.forEach(tag => {
  const mapped = blogTagMappings[tag];
  if (mapped) mapped.forEach(id => serviceIds.add(id));
});

// Fallback services if no tags match
if (serviceIds.size === 0) {
  serviceIds.add('hard-drive-shredding');
  serviceIds.add('macbook-buyback');
}

const services = Array.from(serviceIds).map(id => serviceMappings[id]).filter(Boolean);
---

{ services.length > 0 && (
  <aside class="related-services">
    <h3>Related Services You May Need</h3>
    <ul>
      {services.map(service => (
        <li><a href={service.url}>{service.name}</a></li>
      ))}
    </ul>
  </aside>
)}

<style>
  aside { margin-top: 3rem; padding: 1.5rem; background: var(--card); border-radius: 1rem; border: 1px solid var(--border); }
  aside h3 { margin-bottom: 1rem; color: var(--white); }
  aside ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.75rem; }
  aside a { display: inline-block; padding: 0.5rem 1rem; background: var(--bg); border: 1px solid var(--border); border-radius: 2rem; text-decoration: none; color: var(--green); font-weight: 500; transition: background 0.2s; }
  aside a:hover { background: var(--green); color: black; }
</style>
