---
/**
 * src/components/WikiPageTemplate.astro
 * High-Density "Authority Pillar" Template based on the Industrial Amber theme.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { useTranslations } from '../i18n/ui.js';

interface Chapter {
  id: string;
  num: string;
  title: string;
  content: string; // HTML string or component slot
}

interface Props {
  lang?: string;
  title: string;
  description: string;
  badge: string;
  heroH1: any; // { acc: string; main: string; acc2: string; suffix: string }
  heroDesc: string;
  chapters: Chapter[];
  sidebarLinks: { name: string; url: string }[];
  faqs?: { q: string, a: string }[];
  schema?: any;
  canonical?: string;
  ogImage?: string;
}

const { 
  lang = 'en', 
  title, 
  description, 
  badge,
  heroH1,
  heroDesc,
  chapters,
  sidebarLinks,
  faqs = [],
  schema = {},
  canonical,
  ogImage
} = Astro.props;

const t = useTranslations(lang);
const l = (path: string) => lang === 'en' ? path : `/${lang}${path}`;
---

<BaseLayout 
  title={title} 
  description={description} 
  schema={schema} 
  canonical={canonical}
  ogImage={ogImage}
  faqs={faqs}
>
  <!-- TOPBAR TICKER -->
  <div id="topbar">
    <div id="ticker">
      <span class="tb-item">♻️ Certified Zero-Landfill Electronics Recycling — Kochi</span>
      <span class="tb-item">🔒 NIST/DoD Data Destruction Every Device</span>
      <span class="tb-item">🏭 KSPCB & CPCB Authorized Facility</span>
      <span class="tb-item">🚚 Free Pickup — Kochi & Ernakulam</span>
      <span class="tb-item">⚡ Same-Day Collection — Infopark & Smart City</span>
      <span class="tb-item">🥇 Kerala's #1 Electronics Recycler since 2018</span>
      <span class="tb-item">📞 24/7 Service — +91-75005-55454</span>
      <!-- Loop -->
      <span class="tb-item">♻️ Certified Zero-Landfill Electronics Recycling — Kochi</span>
      <span class="tb-item">🔒 NIST/DoD Data Destruction Every Device</span>
      <span class="tb-item">🏭 KSPCB & CPCB Authorized Facility</span>
      <span class="tb-item">🚚 Free Pickup — Kochi & Ernakulam</span>
    </div>
  </div>

  <Navbar currentPath={Astro.url.pathname} />

  <!-- HERO -->
  <section class="wiki-hero">
    <div class="hero-bg"></div>
    <div class="wrap">
      <div class="hero-inner">
        <div>
          <div class="hero-badge">
            <span class="pulse"></span>
            {badge}
          </div>
          <h1 class="hero-h1">
            <span class="acc">{heroH1.acc}</span><br>
            {heroH1.main}<br>
            <span class="acc2">{heroH1.acc2}</span> {heroH1.suffix}
          </h1>
          <p class="hero-desc">{heroDesc}</p>
          <div class="hero-ctas">
            <a href={l("/contact/")} class="btn btn-primary btn-lg">🚚 Schedule Free Pickup →</a>
            <a href="https://wa.me/917500555454" class="btn btn-wa btn-lg">💬 WhatsApp Now</a>
          </div>
        </div>
        
        <!-- Stats Sidebar Fragment (Visual) -->
        <div class="hero-stats-panel">
           <div class="panel-tag">Material Recovery — Kochi HQ</div>
           <div class="bar-stack">
              <div class="bar-row">
                <div class="bar-labels"><span>🔩 Metals</span><span>94%</span></div>
                <div class="bar-bg"><div class="bar-fill" style="width:94%"></div></div>
              </div>
              <div class="bar-row">
                <div class="bar-labels"><span>💎 Precious</span><span>98%</span></div>
                <div class="bar-bg"><div class="bar-fill" style="width:98%; background: var(--amber)"></div></div>
              </div>
              <div class="bar-row">
                <div class="bar-labels"><span>🧴 Plastics</span><span>88%</span></div>
                <div class="bar-bg"><div class="bar-fill" style="width:88%"></div></div>
              </div>
           </div>
           <div class="panel-footer">
              <div class="footer-val">100%</div>
              <div class="footer-lbl">Zero Landfill Certified · KSPCB Audited</div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WIKI CONTENT -->
  <section class="section">
    <div class="wrap">
      <div class="wiki-grid">
        <main class="wiki-main">
          {chapters.map((ch) => (
            <article class="wiki-chapter" id={ch.id}>
              <div class="chap-num">Chapter {ch.num}</div>
              <h2 class="chap-title" set:html={ch.title} />
              <div class="chap-body" set:html={ch.content} />
            </article>
          ))}
        </main>

        <aside class="wiki-sidebar">
          <div class="sticky-box">
             <h3>📚 Authority Directory</h3>
             <ul class="interlink-list">
               {sidebarLinks.map(link => (
                 <li><a href={link.url}><span class="ico">→</span> {link.name}</a></li>
               ))}
             </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
/* CLONED INDUSTRIAL AMBER THEME FROM RECYCLING.ASTRO */
:root {
  --amber: #F5A623;
  --amber2: #D4891C;
  --lime: #C8FF57;
  --bg-dark: #060809;
  --card-dark: #0C1014;
  --border-dark: #161E22;
}

#topbar { background: var(--amber); padding: 8px 0; overflow: hidden; }
#ticker { display: flex; white-space: nowrap; animation: tick 40s linear infinite; }
.tb-item { font-size: 0.7rem; font-weight: 800; color: #1a0d00; padding: 0 40px; }
@keyframes tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

.wiki-hero { padding: 100px 0; background: linear-gradient(135deg, #060809 0%, #0a0f14 100%); position: relative; overflow: hidden; }
.hero-bg { position: absolute; inset: 0; background: radial-gradient(circle at 80% 20%, rgba(245,166,35,0.06), transparent); }
.hero-inner { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.7rem; color: var(--amber); background: rgba(245,166,35,0.1); padding: 6px 14px; border-radius: 20px; border: 1px solid rgba(245,166,35,0.2); }
.hero-h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; line-height: 1; margin: 20px 0; }
.hero-h1 .acc { color: var(--amber); }
.hero-h1 .acc2 { color: var(--lime); }
.hero-desc { font-size: 1.1rem; color: var(--text); font-family: var(--serif); font-style: italic; max-width: 600px; margin-bottom: 30px; }

.hero-stats-panel { background: var(--card-dark); border: 1px solid var(--border-dark); border-top: 2px solid var(--amber); padding: 30px; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
.panel-tag { font-size: 0.7rem; color: var(--amber); font-weight: 800; text-transform: uppercase; margin-bottom: 15px; }
.bar-stack { display: flex; flex-direction: column; gap: 12px; }
.bar-labels { display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 5px; color: var(--white); }
.bar-bg { height: 6px; background: #161e22; border-radius: 10px; }
.bar-fill { height: 100%; background: var(--lime); border-radius: 10px; }
.panel-footer { margin-top: 20px; text-align: center; border-top: 1px solid #161e22; padding-top: 15px; }
.footer-val { font-size: 2rem; font-weight: 900; color: var(--white); }
.footer-lbl { font-size: 0.65rem; color: var(--muted); text-transform: uppercase; }

.wiki-grid { display: grid; grid-template-columns: 1fr 300px; gap: 50px; }
.wiki-chapter { margin-bottom: 70px; }
.chap-num { font-size: 0.7rem; color: var(--amber); text-transform: uppercase; font-weight: 800; letter-spacing: 0.1em; display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.chap-num::after { content: ''; flex: 1; height: 1px; background: rgba(245,166,35,0.2); }
.chap-title { font-size: 2rem; color: var(--white); margin-bottom: 20px; }
.chap-body { font-size: 1rem; line-height: 1.8; color: var(--text); font-family: var(--serif); }
.chap-body :global(p) { margin-bottom: 1.5rem; }
.chap-body :global(strong) { color: var(--white); }
.chap-body :global(ul) { padding-left: 1.5rem; margin-bottom: 1.5rem; }
.chap-body :global(li) { margin-bottom: 0.5rem; }

.sticky-box { position: sticky; top: 100px; background: var(--card-dark); border: 1px solid var(--border-dark); padding: 25px; border-radius: 15px; }
.interlink-list { list-style: none; margin-top: 15px; }
.interlink-list li { margin-bottom: 8px; }
.interlink-list a { font-size: 0.85rem; color: var(--muted); display: flex; align-items: center; gap: 8px; }
.interlink-list a:hover { color: var(--amber); }

@media (max-width: 1024px) {
  .hero-inner { grid-template-columns: 1fr; }
  .wiki-grid { grid-template-columns: 1fr; }
}
</style>
