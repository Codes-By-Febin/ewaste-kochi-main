---
/**
 * WhatsAppCTA.astro
 * ─────────────────────────────────────────────────────────────────
 * Sticky mobile-only WhatsApp Call-to-Action bar.
 *
 * Why tasteful & non-intrusive:
 *   - Only visible on mobile screens (hidden desktop via CSS media query)
 *   - Anchored to bottom of viewport — does not block content
 *   - Appears after 3 seconds of page engagement (scroll-triggered)
 *   - Pre-fills contextual message so user knows what they're sending
 *   - No popup, no overlay, no forced interaction
 *
 * Usage:
 *   <WhatsAppCTA context="itad" />           → prefills ITAD message
 *   <WhatsAppCTA context="recycling" />      → prefills recycling message
 *   <WhatsAppCTA context="data-destruction" />
 *   <WhatsAppCTA service="Laptop Buyback" /> → custom service name
 */

import { contact } from '../data/contact.js';

interface Props {
  context?: 'itad' | 'recycling' | 'data-destruction' | 'battery' | 'buyback' | 'general';
  service?: string;
  hideAfterScroll?: boolean;
}

const { context = 'general', service, hideAfterScroll = false } = Astro.props;

// Build contextual pre-filled messages
const messages: Record<string, string> = {
  'itad': `Hi! I need ITAD services for my company in Kochi. Can you help with device pickup and data destruction?`,
  'recycling': `Hi! I'd like to schedule a free e-waste pickup for my home/office in Kochi.`,
  'data-destruction': `Hi! I need certified data destruction for our old hard drives. Please share details.`,
  'battery': `Hi! I have old batteries to recycle. Can you arrange a safe pickup in Kochi?`,
  'buyback': `Hi! I want to sell my old ${service || 'electronics'}. Can you give me a quote?`,
  'general': `Hi! I need help with e-waste disposal/recycling in Kochi. What services do you offer?`,
};

const selectedMessage = service && context === 'general'
  ? `Hi! I need help with ${service} in Kochi. Please share your rates and availability.`
  : messages[context] || messages['general'];

const waUrl = `${contact.whatsappBase}?text=${encodeURIComponent(selectedMessage)}`;
---

<!-- Mobile sticky WhatsApp CTA — hidden on desktop -->
<div id="wa-sticky-cta" aria-label="Chat on WhatsApp" role="complementary">
  <a
    href={waUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="wa-cta-inner"
    id="wa-sticky-link"
    aria-label="Chat with EWaste Kochi on WhatsApp"
  >
    <div class="wa-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/>
      </svg>
    </div>
    <div class="wa-text">
      <span class="wa-label">Chat on WhatsApp</span>
      <span class="wa-sub">Free quote · Instant reply</span>
    </div>
    <div class="wa-arrow" aria-hidden="true">→</div>
  </a>
  <button class="wa-close" id="wa-close-btn" aria-label="Close WhatsApp CTA">✕</button>
</div>

<style>
  #wa-sticky-cta {
    display: none; /* Hidden by default, shown via JS after delay */
    position: fixed;
    bottom: 16px;
    left: 16px;
    right: 16px;
    z-index: 9000;
    align-items: center;
    gap: 10px;
  }

  /* Only show on mobile */
  @media (max-width: 768px) {
    #wa-sticky-cta.visible {
      display: flex;
    }
  }

  .wa-cta-inner {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: #25D366;
    border-radius: 16px;
    text-decoration: none;
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.45), 0 2px 8px rgba(0,0,0,0.2);
    color: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .wa-cta-inner:active {
    transform: scale(0.97);
  }

  .wa-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wa-text {
    flex: 1;
  }

  .wa-label {
    display: block;
    font-size: 0.95rem;
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
  }

  .wa-sub {
    display: block;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.82);
    margin-top: 2px;
  }

  .wa-arrow {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    font-weight: 700;
    flex-shrink: 0;
  }

  .wa-close {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(5, 9, 8, 0.85);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    font-size: 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    backdrop-filter: blur(8px);
  }

  /* Entrance animation */
  @keyframes wa-slide-up {
    from { transform: translateY(100px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  #wa-sticky-cta.visible {
    animation: wa-slide-up 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
</style>

<script>
  // Show after 3.5s or after user scrolls 40% of page — whichever comes first
  const cta = document.getElementById('wa-sticky-cta');
  const closeBtn = document.getElementById('wa-close-btn');
  const DISMISSED_KEY = 'wa_cta_dismissed';

  function showCTA() {
    if (!cta) return;
    if (sessionStorage.getItem(DISMISSED_KEY)) return; // Respect dismissal within session
    cta.classList.add('visible');
  }

  // Timer trigger
  const timer = setTimeout(showCTA, 3500);

  // Scroll trigger
  function onScroll() {
    const scrolled = window.scrollY / (document.body.scrollHeight - window.innerHeight);
    if (scrolled > 0.4) {
      clearTimeout(timer);
      showCTA();
      window.removeEventListener('scroll', onScroll);
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  // Dismiss button
  if (closeBtn) {
    closeBtn.addEventListener('click', () => {
      if (cta) cta.classList.remove('visible');
      sessionStorage.setItem(DISMISSED_KEY, '1');
    });
  }
</script>
