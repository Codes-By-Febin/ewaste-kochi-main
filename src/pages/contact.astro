---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact EWaste Kochi - Free Pickup & Quote" description="Call, email, or fill the form for instant e-waste pickup quote. Same-day service available.">
  <h1>Contact Us</h1>
  <p>Phone: +91-XXXX-XXXXXX</p>
  <p>Email: hello@ewastekochi.com</p>
  <form action="/api/contact" method="post">
    <input type="text" name="name" placeholder="Your name" required>
    <input type="email" name="email" placeholder="Your email" required>
    <textarea name="message" placeholder="Tell us about your e-waste"></textarea>
    <button type="submit">Send Message</button>
  </form>
</BaseLayout>
