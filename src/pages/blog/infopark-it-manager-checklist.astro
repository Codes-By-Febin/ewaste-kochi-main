---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = 'Infopark IT Manager Checklist: 5-Point Guide Before Disposing Company Laptops';
const description = 'Essential checklist for IT managers in Infopark before disposing of company laptops. Data security, compliance, and ITAD best practices for Kerala businesses.';
const pubDate = '2026-04-17';
---

<BaseLayout title={title} description={description}>
  <Navbar currentPath="/blog/" />
  <article class="py-20">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="text-4xl font-bold mb-4">Infopark IT Manager Checklist</h1>
      <p class="text-gray-600 mb-8">5-Point Guide Before Disposing Company Laptops</p>
      <div class="prose max-w-none">
        <p>Essential checklist for IT managers in Infopark before disposing of company laptops...</p>
      </div>
    </div>
  </article>
  <Footer />
</BaseLayout>
