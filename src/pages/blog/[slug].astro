---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../components/BlogPost.astro';
import { getCollection } from 'astro:content';
import BlogInternalLinkingEngine from '../../utils/blogInternalLinkingEngine.js';

export async function getStaticPaths() {
  const blogs = await getCollection('blog');
  const linkingEngine = new BlogInternalLinkingEngine();
  
  // Process all blog posts with internal linking optimization
  const processedBlogs = blogs.map(blog => linkingEngine.processBlogPost(blog, blogs));
  
  return processedBlogs.map(blog => ({
    params: { slug: blog.slug },
    props: { 
      blog: blog,
      allBlogs: processedBlogs
    },
  }));
}

const { blog, allBlogs } = Astro.props;

// Extract table of items from processed blog
const tableOfContents = blog.data.tableOfContents || [];
const relatedPosts = blog.data.relatedPosts || [];
---

<BlogPost 
  post={blog}
  relatedPosts={relatedPosts}
  tableOfContents={tableOfContents}
/>
