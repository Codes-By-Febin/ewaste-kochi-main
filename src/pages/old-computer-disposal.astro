---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';

const meta = {
  title: 'Old Computer Disposal | Where to Dispose Old Computers in Kochi',
  description: 'Professional old computer disposal services with secure data destruction, environmental compliance, and local pickup across Kerala. Certified e-waste management for businesses and households.',
  keywords: ['where to dispose old computers', 'old computer disposal', 'computer disposal kochi', 'secure computer recycling', 'e-waste disposal kochi', 'old laptop disposal'],
  canonical: 'https://ewaste-kochi.com/old-computer-disposal'
};
---

<Layout meta={meta}>
  <section class="hero">
    <div class="hero-content">
      <h1>Old Computer Disposal</h1>
      <p>Professional, certified, and secure disposal of old computers and laptops. Complete data destruction, environmental compliance, and local pickup services across Kochi and Kerala.</p>
      <div class="cta-buttons">
        <a href="#disposal-process" class="btn btn-primary">Disposal Process</a>
        <a href="#data-security" class="btn btn-secondary">Data Security</a>
        <a href="#local-services" class="btn btn-primary">Local Services</a>
      </div>
    </div>
  </section>

  <section id="disposal-process" class="container">
    <h2>Disposal Process</h2>
    <div class="process-grid">
      <div class="process-step">
        <h3>1. Collection & Assessment</h3>
        <p>Our team collects your old computers from your location and performs a comprehensive assessment. We document the condition, specifications, and identify reusable components for maximum recovery value.</p>
      </div>
      <div class="process-step">
        <h3>2. Data Security & Wiping</h3>
        <p>Before any physical disposal, we ensure complete data destruction using NIST 800-88 compliant methods. All personal and business data is permanently wiped from storage devices.</p>
      </div>
      <div class="process-step">
        <h3>3. Component Separation</h3>
        <p>Computers are carefully disassembled to separate valuable materials: circuit boards, memory chips, processors, plastics, and metals are sorted for optimal recycling.</p>
      </div>
      <div class="process-step">
        <h3>4. Material Recovery</h3>
        <p>Advanced recovery processes extract precious metals (gold, silver, copper) and valuable materials from components, reducing the need for virgin resource extraction.</p>
      </div>
      <div class="process-step">
        <h3>5. Environmentally Responsible Disposal</h3>
        <p>Non-recyclable materials are disposed of through certified hazardous waste facilities, ensuring full environmental compliance and zero landfill dumping.</p>
      </div>
      <div class="process-step">
        <h3>6. Certificate of Destruction</h3>
        <p>Receive a detailed certificate documenting the entire disposal process, including serial numbers, timestamps, and chain of custody for audit and compliance purposes.</p>
      </div>
    </div>
  </section>

  <section id="data-security" class="container bg-gray-50">
    <h2>Data Security & Privacy</h2>
    <div class="security-features">
      <div class="feature-card">
        <h3>Certified Data Destruction</h3>
        <p>Following NIST 800-88 guidelines for media sanitization, we ensure your personal and business data is permanently unrecoverable through multiple destruction methods.</p>
      </div>
      <div class="feature-card">
        <h3>Chain of Custody Documentation</h3>
        <p>Complete tracking from pickup through processing, with detailed logs for your compliance, audit requirements, and regulatory documentation.</p>
      </div>
      <div class="feature-card">
        <h3>On-Site Data Wiping</h3>
        <p>Available for enterprise clients who require data destruction to be performed at their location under supervision with full video documentation.</p>
      </div>
      <div class="feature-card">
        <h3>Certificate of Destruction</h3>
        <p>Receive detailed certificates for each device including serial numbers, destruction timestamps, methods used, and compliance certifications.</p>
      </div>
    </div>
  </section>

  <section id="environmental-impact" class="container">
    <h2>Environmental Impact</h2>
    <div class="environmental-content">
      <div class="environmental-info">
        <h3>Why Proper Computer Disposal Matters</h3>
        <p>Old computers contain hazardous materials including lead, mercury, cadmium, and brominated flame retardants. When disposed of improperly, these toxins leach into soil and groundwater, contaminating our environment and food chain.</p>
        <p>Proper e-waste recycling recovers valuable materials like gold, silver, copper, and rare earth elements, reducing the need for destructive mining operations and conserving natural resources.</p>
      </div>
      <div class="environmental-stats">
        <div class="stat-box">
          <h4>1 Computer</h4>
          <p>Recycled prevents 250kg of CO2 emissions</p>
        </div>
        <div class="stat-box">
          <h4>1 Ton</h4>
          <p>E-waste contains 80x more gold than ore</p>
        </div>
        <div class="stat-box">
          <h4>100%</h4>
          <p>Zero landfill disposal commitment</p>
        </div>
      </div>
    </div>
  </section>

  <section id="local-services" class="container bg-gray-50">
    <h2>Local Services in Kochi</h2>
    <div class="service-cards">
      <div class="service-card">
        <h3>Residential Pickup</h3>
        <p>Free consultation and pickup for households. We serve all major areas in Kochi with no minimum quantity requirements. Schedule convenient pickup times including weekends.</p>
        <ul>
          <li>Free consultation and quote</li>
          <li>Flexible scheduling including weekends</li>
          <li>Same-day pickup available</li>
          <li>Service for single devices to bulk collections</li>
        </ul>
      </div>
      <div class="service-card">
        <h3>Business/Office Services</h3>
        <p>Corporate e-waste management solutions with dedicated account management and customized pickup schedules for offices, IT departments, and commercial clients.</p>
        <ul>
          <li>Large volume discount programs</li>
          <li>On-site data destruction services</li>
          <li>Compliance reporting and documentation</li>
          <li>Scheduled recurring pickups</li>
        </ul>
      </div>
      <div class="service-card">
        <h3>Drop-Off Locations</h3>
        <p>Visit our certified e-waste recycling centers for self-drop off services. Secure kiosks available 24/7 at select locations with immediate processing and documentation.</p>
        <ul>
          <li>Find locations near you</li>
          <li>Extended hours operation</li>
          <li>Immediate processing and documentation</li>
          <li>Competitive pricing per unit</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="service-categories" class="container">
    <h2>Additional Computer Services</h2>
    <div class="service-cards">
      <div class="service-card">
        <h3>Laptop Recycling</h3>
        <p>Complete recycling service for laptops with battery handling, screen removal, and component separation for maximum material recovery.</p>
      </div>
      <div class="service-card">
        <h3>Hard Drive Destruction</h3>
        <p>Physical destruction of hard drives and solid-state drives using industrial shredders for maximum security and compliance.</p>
      </div>
      <div class="service-card">
        <h3>Desktop Computer Disposal</h3>
        <p>Complete disposal of desktop towers, monitors, keyboards, and accessories with proper hazardous material handling.</p>
      </div>
      <div class="service-card">
        <h3>Printer & Copier Recycling</h3>
        <p>Environmentally responsible disposal of office equipment including ink cartridges and imaging devices.</p>
      </div>
    </div>
  </section>

  <section id="contact" class="container">
    <h2>Ready to Dispose of Your Old Computer?</h2>
    <p>Contact us today for secure, certified, and affordable old computer disposal with local pickup across Kochi. Get your free quote and certificate of destruction.</p>
    <ContactForm />
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #3a7bd5 100%);
    color: white;
    padding: 120px 0;
    text-align: center;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .hero-content p {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .process-step {
    background: #f8f9fa;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #2a5298;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .process-step:hover {
    transform: translateY(-5px);
  }

  .process-step h3 {
    margin-bottom: 1rem;
    color: #1e3c72;
  }

  .environmental-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .environmental-info h3 {
    color: #1e3c72;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .environmental-info p {
    line-height: 1.9;
    color: #555;
    margin-bottom: 1rem;
  }

  .environmental-stats {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stat-box {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    text-align: center;
  }

  .stat-box h4 {
    color: #2a5298;
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .stat-box p {
    color: #666;
    margin: 0;
    font-size: 0.95rem;
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .service-card h3 {
    color: #2a5298;
    margin-bottom: 1rem;
    font-size: 1.3rem;
  }

  .service-card ul {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }

  .service-card li {
    padding: 0.5rem 0;
    position: relative;
    padding-left: 1.5rem;
    color: #555;
  }

  .service-card li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2a5298;
    font-weight: bold;
  }

  .section {
    padding: 80px 0;
  }

  .section h2 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 3rem;
    color: #1e3c72;
  }

  .bg-gray-50 {
    background: #f8f9fa;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }

    .environmental-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .section h2 {
      font-size: 2rem;
    }
  }
</style>
