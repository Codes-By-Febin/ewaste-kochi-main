---
// old-computer-disposal.astro — High-Intent Landing Page
// GSC targets: "old computer disposal", "dispose old computers", "old computer disposal near me"
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';

const pageTitle = "Old Computer Disposal Kochi | Safe Disposal | Free Pickup | Data Wiped | EWaste Kochi";
const pageDesc = "Dispose of old computers safely in Kochi. Desktops, laptops, all brands. Free business pickup. NIST data destruction. KSPCB authorized. Certificate provided. Call 24/7.";

const whyDispose = [
  { icon: '🔐', title: 'Data Security Risk', desc: 'Old computers store personal & business data. Simple deletion is not enough. Certified data destruction prevents identity theft and legal liability.' },
  { icon: '⚖️', title: 'Legal Compliance', desc: 'E-Waste Rules 2022 require authorized disposal. Non-compliance can lead to fines up to ₹1 lakh per ton. We provide Certificates of Disposal.' },
  { icon: '🌱', title: 'Environmental Harm', desc: 'Computers contain hazardous substances like lead, mercury, cadmium. Proper disposal prevents soil & water contamination.' },
  { icon: '💰', title: 'Cost Savings', desc: 'Free pickup for 10+ computers. No disposal fees. Avoid potential regulatory penalties.' },
];

const whatWeAccept = [
  'Desktop PCs (towers, small form factor, all-in-ones)',
  'Laptops & notebooks (any brand, any condition)',
  'CRT & flat-panel monitors',
  'Servers & rack units',
  'Computer peripherals (keyboards, mice, cables, chargers)',
  'Tablets & e-readers',
  'Gaming consoles & accessories',
];

const processSteps = [
  { step: '1', title: 'Schedule Pickup', desc: 'Call or WhatsApp with number of computers, types, and location across Kochi.' },
  { step: '2', title: 'Inventory & Documentation', desc: 'We create an inventory list with serial numbers, condition, and photographs. Provides chain of custody.' },
  { step: '3', title: 'Secure Data Destruction', desc: 'All storage drives undergo NIST 800-88 certified wiping or physical destruction. You receive a Certificate of Destruction.' },
  { step: '4', title: 'Responsible Recycling', desc: 'Computers are dismantled. Valuable materials recovered; hazardous components disposed safely. Zero landfill commitment.' },
  { step: '5', title: 'Certificate of Disposal', desc: 'You receive a Certificate of Disposal with weight, item list, and KSPCB authorization details.' },
];

const pricing = [
  { title: 'Business Pickup (10+ computers)', price: 'Free', includes: ['Free pickup anywhere in Kochi', 'NIST data destruction', 'Certificate of Disposal', 'Full audit documentation'] },
  { title: 'Residential Drop-off (<10 items)', price: 'Free', includes: ['Drop-off at Thrippunithura facility', 'Optional data destruction ₹299/drive', 'Eco-friendly recycling'] },
  { title: 'Data Destruction Only', price: '₹299/drive', includes: ['NIST 800-88 Purge', 'Certificate of Destruction', 'Chain of custody logs'] },
];

const faqs = [
  { q: 'How do I dispose of an old computer?', a: 'Contact EWaste Kochi to schedule a free pickup (10+ items). We collect, securely destroy data, recycle responsibly, and issue a Certificate of Disposal. For fewer items, drop-off at our Thrippunithura facility is free.' },
  { q: 'Is it safe to throw away an old computer?', a: 'No. Never throw computers in regular trash. They contain hazardous materials and store personal data. Use an authorized recycler like EWaste Kochi for safe, compliant disposal.' },
  { q: 'Will my data be wiped?', a: 'Yes. We provide NIST 800-88 certified data destruction on all storage devices. You receive a Certificate of Destruction with serial numbers, method, and date. Legally valid for DPDP Act 2023.' },
  { q: 'Do you pickup old computers from homes?', a: 'Yes, we serve both residential and commercial clients across Kochi. For 10+ computers, pickup is free. For <10, you can drop off at our facility for free or request a paid collect.' },
  { q: 'What happens to old computers?', a: 'After data destruction, computers are dismantled. Reusable materials (metals, plastics) are recycled. Hazardous components (batteries, CRTs) are handled separately per E-Waste Rules 2022.' },
  { q: 'Can you destroy hard drives only?', a: 'Yes. If you only need data destruction, we can shred drives and recycle the rest of the computer or return it to you.' },
  { q: 'Do you provide a certificate?', a: 'Yes. Every disposal gets a Certificate of Disposal listing items, weight, date, and our KSPCB authorization number. Essential for corporate ESG reporting.' },
  { q: 'Which brands do you accept?', a: 'All brands: Dell, HP, Lenovo, Apple, Asus, Acer, Samsung, Microsoft, and more. Any condition, any age.' },
];

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Old Computer Disposal', url: 'https://ewastekochi.com/old-computer-disposal/' },
];

const serviceSchema = {
  '@type': 'RecyclingService',
  name: 'Old Computer Disposal Kochi',
  description: pageDesc,
  provider: { '@id': 'https://ewastekochi.com/#organization' },
  areaServed: { '@type': 'City', name: 'Kochi' },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'INR',
    description: 'Free pickup for 10+ computers; drop-off always free',
  },
};
---

<BaseLayout title={pageTitle} description={pageDesc} schema={serviceSchema} faqs={faqs} breadcrumbs={breadcrumbs}>
  <Navbar currentPath="/old-computer-disposal/" />

  <!-- HERO -->
  <section style="padding:80px 0 60px;background:radial-gradient(circle at 70% 30%,rgba(0,232,150,.07),transparent),var(--bg)">
    <div class="wrap">
      <nav aria-label="Breadcrumb" style="font-size:.8rem;color:var(--muted);margin-bottom:20px">
        <a href="/" style="color:var(--green)">Home</a> › Old Computer Disposal
      </nav>
      <div class="badge badge-g" style="margin-bottom:20px">♻️ KSPCB Authorized · Data Wiped</div>
      <h1 style="font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.05;margin-bottom:18px;font-weight:800;letter-spacing:-.03em">
        Safe <span style="color:var(--green)">Old Computer</span><br/>Disposal in Kochi
      </h1>
      <p style="font-size:1rem;color:var(--text);max-width:620px;line-height:1.7;margin-bottom:35px;font-family:var(--serif);font-style:italic">
        Free pickup for 10+ computers. NIST-certified data destruction included. KSPCB authorized recycler. Certificate of Disposal provided. Serving all of Ernakulam — Infopark, Smart City, Kakkanad, and more.
      </p>
      <div style="display:flex;gap:15px;flex-wrap:wrap">
        <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">💬 Book Pickup</a>
        <a href={contact.phoneLink} class="btn btn-primary btn-lg">📞 {contact.phoneDisplay}</a>
        <a href="/contact/" class="btn btn-outline">Get Quote</a>
      </div>
    </div>
  </section>

  <!-- WHY DISPOSE -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">Why Proper Disposal Matters</div>
      <h2 class="sec-title">Computers Aren’t <em>Trash</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-top:30px">
        {whyDispose.map(item => (
          <div style="text-align:center;padding:24px;background:var(--card);border-radius:14px;border:1px solid var(--border)">
            <div style="font-size:2.5rem;margin-bottom:12px">{item.icon}</div>
            <h3 style="font-size:1.1rem;margin-bottom:10px;color:var(--text)">{item.title}</h3>
            <p style="font-size:.9rem;color:var(--muted);line-height:1.6">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE ACCEPT -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">What We Accept</div>
      <h2 class="sec-title">All Old Computers & <em>Peripherals</em></h2>
      <p style="max-width:700px;margin-bottom:24px">
        From a single old desktop to hundreds of office PCs, we accept all computer equipment — any brand, any condition.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:20px">
        {whatWeAccept.map(item => (
          <span class="badge" style="font-size:1rem;padding:10px 18px">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">Our Process</div>
      <h2 class="sec-title">From Pickup to <em>Certificate</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:30px">
        {processSteps.map(step => (
          <div style="background:var(--card);border-radius:16px;padding:28px;text-align:center;border:1px solid var(--border)">
            <div style="font-size:2.5rem;color:var(--green);font-weight:800;margin-bottom:12px">{step.step}</div>
            <h3 style="font-size:1.1rem;margin-bottom:10px">{step.title}</h3>
            <p style="font-size:.9rem;color:var(--muted);line-height:1.6">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Pricing</div>
      <h2 class="sec-title">Transparent <em>Costs</em></h2>
      <div style="display:grid;gap:20px;max-width:800px;margin:0 auto">
        {pricing.map(p => (
          <div style="background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px">
            <div style="flex:1;min-width:200px">
              <h3 style="font-size:1.2rem;margin-bottom:8px;color:var(--text)">{p.title}</h3>
              <div style="font-size:2rem;color:var(--green);font-weight:800">{p.price}</div>
            </div>
            <div style="flex:1;min-width:200px">
              <ul style="list-style:none;padding:0;margin:0;display:grid;gap:6px;font-size:.9rem;color:var(--muted)">
                {p.includes.map(feat => <li>✓ {feat}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COVERAGE -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">Service Area</div>
      <h2 class="sec-title">We Pick Up Across <em>Kochi</em></h2>
      <p style="max-width:700px;margin-bottom:16px">
        Free pickup for businesses with 10+ computers anywhere in Kochi and Ernakulam district. Same-day or next-day service available for Infopark, Smart City, Kakkanad, Edapally, Vyttila, Palarivattom, Aluva, Angamaly, Thrippunithura, and all surrounding areas.
      </p>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <span class="badge">Infopark</span>
        <span class="badge">Smart City</span>
        <span class="badge">Kakkanad</span>
        <span class="badge">Edapally</span>
        <span class="badge">Vyttila</span>
        <span class="badge">Aluva</span>
        <span class="badge">Thrippunithura</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="wrap">
      <div style="background:linear-gradient(135deg,var(--green),var(--green-dark));color:var(--white);border-radius:20px;padding:50px;text-align:center;margin:60px 0">
        <h2 style="font-size:2rem;margin-bottom:20px">Ready to Dispose of Old Computers?</h2>
        <p style="font-size:1.1rem;margin-bottom:30px;opacity:0.9">Call or WhatsApp now for a free pickup. Certificate of Disposal included. Serving all of Kochi.</p>
        <div style="display:flex;gap:15px;flex-wrap:wrap;justify-content:center">
          <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn" style="background:var(--white);color:var(--green);font-weight:800;font-size:1.1rem;padding:16px 32px">💬 WhatsApp</a>
          <a href={contact.phoneLink} class="btn" style="background:transparent;border:2px solid var(--white);color:var(--white);font-size:1.1rem;padding:14px 30px">📞 Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Questions?</div>
      <h2 class="sec-title">Old Computer Disposal — <em>FAQs</em></h2>
      <div style="display:grid;gap:16px;max-width:800px;margin:0 auto">
        {faqs.map((faq, i) => (
          <details style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 20px">
            <summary style="font-weight:600;cursor:pointer;font-size:1.05rem">{faq.q}</summary>
            <p style="margin-top:12px;color:var(--muted);line-height:1.7">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
