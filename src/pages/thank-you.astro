---
// src/pages/thank-you.astro — Post-form submission confirmation page
// IMPORTANT: This page is noindexed — it's only for post-conversion UX
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';

const title = 'Thank You — Your Message Was Sent | EWaste Kochi';
const description = 'Thank you for contacting EWaste Kochi. We\'ll respond within 4 hours. Here\'s what happens next.';
---

<BaseLayout
  title={title}
  description={description}
  noIndex={true}
>
  <Navbar currentPath="/thank-you/" />

  <main style="min-height: 85vh; display: flex; align-items: center;">
    <div class="wrap" style="max-width: 700px; margin: 0 auto; text-align: center; padding: 60px 20px;">
      
      <!-- Success Animation -->
      <div class="success-icon" aria-hidden="true">✅</div>

      <h1 style="font-size: clamp(2rem, 5vw, 3rem); line-height: 1.1; margin-bottom: 20px; color: var(--white);">
        Message <em style="color: var(--green);">Received.</em>
        <br/>We're On It.
      </h1>

      <p style="font-size: 1.1rem; color: var(--text); line-height: 1.75; margin-bottom: 50px; max-width: 560px; margin-left: auto; margin-right: auto;">
        Our ITAD specialists will get back to you within <strong style="color: var(--white);">4 hours</strong> on business days.
        For urgent requests, WhatsApp is always faster.
      </p>

      <!-- What Happens Next -->
      <div class="steps-grid">
        {[
          { n: '01', icon: '📋', label: 'We Review Your Request', body: 'Our team reviews your device list and project requirements within 4 hours.' },
          { n: '02', icon: '💰', label: 'You Receive a Quote', body: 'We send a clear, itemized quote — pickup costs, any buyback amounts, and documentation fees.' },
          { n: '03', icon: '🚛', label: 'Pickup Scheduled', body: 'We agree on a date and time. Our team shows up with all necessary paperwork and equipment.' },
          { n: '04', icon: '📜', label: 'Certificate Delivered', body: 'Your Certificate of Destruction and KSPCB manifest arrive within 24 hours of completion.' },
        ].map(step => (
          <div class="step-card">
            <div class="step-num">{step.n}</div>
            <div class="step-icon">{step.icon}</div>
            <h3 class="step-label">{step.label}</h3>
            <p class="step-body">{step.body}</p>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div class="ty-ctas">
        <a
          href={`${contact.whatsappBase}?text=Hi%2C+I+just+submitted+a+contact+form+and+want+to+expedite+my+request.`}
          class="btn btn-wa"
          target="_blank"
          rel="noopener"
          id="ty-wa-btn"
        >
          💬 WhatsApp for Faster Response
        </a>
        <a href={contact.phoneLink} class="btn btn-outline" id="ty-call-btn">
          📞 Call {contact.phoneDisplay}
        </a>
      </div>

      <!-- Helpful links -->
      <div class="ty-links">
        <p style="font-size: 0.78rem; color: var(--muted); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.08em;">While you wait</p>
        <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 40px;">
          <a href="/itad-faq-kochi/" class="ty-link">ITAD FAQ →</a>
          <a href="/case-studies/" class="ty-link">Client Case Studies →</a>
          <a href="/itad/nist-800-88-vs-dod-5220-22m/" class="ty-link">NIST vs DoD Guide →</a>
          <a href="/itad/server-decommissioning-checklist/" class="ty-link">Server Checklist →</a>
        </div>
      </div>

      <!-- Google Review Loop -->
      <div style="background: rgba(245, 245, 245, 0.03); border: 1px solid var(--border); border-radius: 20px; padding: 40px 30px; margin: 40px 0;">
        <h3 style="color: var(--white); margin-bottom: 8px;">Happy with our service?</h3>
        <p style="font-size: 0.9rem; color: var(--text); margin-bottom: 24px;">Help Kochi businesses find sustainable electronics disposal. Please leave us a review on Google.</p>
        <a href="https://g.page/r/YOUR_REVIEW_LINK_HERE/review" target="_blank" class="btn btn-outline" style="border-color: var(--amber); color: var(--amber);">
          ⭐⭐⭐⭐⭐ Rate us on Google
        </a>
      </div>

      <!-- Facility Proof Carousel -->
      <div style="margin-top: 60px;">
        <p style="font-size: 0.78rem; color: var(--muted); margin-bottom: 24px; text-transform: uppercase; letter-spacing: 0.08em;">Inside our Kochi Processing Hub</p>
        <div class="facility-grid">
          <img src="/img/kochi_facility_processing.png" alt="ITAD specialists disassembling corporate laptops at Kochi facility" style="border-radius: 12px; border: 1px solid var(--border);" />
          <img src="/img/kochi_facility_shredding.png" alt="Industrial hard drive shredding line in action" style="border-radius: 12px; border: 1px solid var(--border);" />
          <img src="/img/kochi_facility_pickup_fleet.png" alt="EWaste Kochi secure logistics fleet" style="border-radius: 12px; border: 1px solid var(--border);" />
        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<!-- GA4 / GTM conversion event fire on page load -->
<script>
  // Fire conversion event when thank-you page loads
  // This works with both Google Analytics 4 and GTM
  if (typeof window !== 'undefined') {
    // GTM dataLayer push
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'contact_form_submission',
      event_category: 'Lead',
      event_label: 'Contact Form',
      conversion_value: 1,
    });

    // GA4 gtag (fallback if not using GTM)
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', {
        event_category: 'Contact',
        event_label: 'Form Submit',
        value: 1,
      });
    }
  }
</script>

<style>
  .success-icon {
    font-size: 4rem;
    margin-bottom: 30px;
    display: block;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes pop {
    from { transform: scale(0); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 50px;
    text-align: left;
  }

  .step-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    position: relative;
  }

  .step-num {
    font-size: 0.65rem;
    color: var(--green);
    font-weight: 800;
    letter-spacing: 0.15em;
    margin-bottom: 10px;
  }

  .step-icon {
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .step-label {
    font-size: 0.9rem;
    color: var(--white);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .step-body {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .ty-ctas {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 50px;
  }

  .ty-links {
    border-top: 1px solid var(--border);
    padding-top: 30px;
  }

  .ty-link {
    padding: 10px 18px;
    border: 1px solid var(--border);
    border-radius: 30px;
    font-size: 0.8rem;
    color: var(--text);
    transition: border-color 0.2s, color 0.2s;
  }

  .ty-link:hover {
    border-color: var(--green);
    color: var(--green);
  }

  .facility-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
  }

  .facility-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  @media (max-width: 600px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
    .facility-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
