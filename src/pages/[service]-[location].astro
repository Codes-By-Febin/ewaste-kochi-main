---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  const locations = await getCollection('locations');
  // Only top 3 services & top 5 locations to avoid bloat
  const topServiceSlugs = ['free-ewaste-pickup-kochi', 'data-destruction-kochi', 'laptop-recycling-kochi'];
  const topLocationSlugs = ['kakkanad', 'edappally', 'aluva', 'vyttila', 'infopark-kochi'];
  
  const paths = [];
  for (const service of services) {
    if (!topServiceSlugs.includes(service.slug)) continue;
    for (const loc of locations) {
      if (!topLocationSlugs.includes(loc.slug)) continue;
      paths.push({
        params: { service: service.slug, location: loc.slug },
        props: { service, location: loc },
      });
    }
  }
  return paths;
}

const { service, location } = Astro.props;
const title = `${service.data.title} in ${location.data.area}`;
const description = `${service.data.description} Serving ${location.data.area} (${location.data.pincode}). Free pickup, certified disposal.`;
---

<BaseLayout title={title} description={description}>
  <h1>{title}</h1>
  <p>{description}</p>
  <p>Same-day service in {location.data.area}</p>
  <p>Call us: +91-XXXX-XXXXXX</p>
  <a href="/contact/" class="cta">Book Free Pickup</a>
</BaseLayout>
