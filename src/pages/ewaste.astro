---
import WikiPageTemplate from '../components/WikiPageTemplate.astro';
import { services } from '../data/services.js';
import { blogs } from '../data/blogs.js';
import { locations } from '../data/locations.js';

const ewasteCanonical = 'https://ewastekochi.com/ewaste/';

// Sidebar links
const sidebarLinks = [
  ...services.map(s => ({ name: s.name, url: `/services/${s.slug}/` })),
  ...locations.slice(0, 10).map(loc => ({ name: `Collection in ${loc.name}`, url: `/locations/${loc.slug}/e-waste-collection-kochi/` }))
];

const chapters = [
  {
    id: "ch1",
    num: "01",
    title: "The <em>E-Waste Crisis</em> in Kochi's Urban Ecosystem",
    content: `
      <p>Electronic waste is the fastest-growing waste stream globally. Kochi, as the metropolitan hub for IT parks and maritime trade, generates thousands of tonnes of discarded hardware annually.</p>
      <p>The "crisis" is the toxicity of mismanagement. When electronics leak into informal scrap shops, mercury and lead contaminate Kerala's sensitive backwaters. EWaste Kochi provides the certified, zero-landfill alternative.</p>
    `
  },
  {
    id: "ch2",
    num: "02",
    title: "Decoding the <em>E-Waste Rules 2022</em> for Kerala Businesses",
    content: `
      <p>The 2022 Rules introduced strict Extended Producer Responsibility (EPR) targets. For Kochi businesses, maintaining asset registers is no longer optional.</p>
      <p>Our facility provides the legally-binding documentation—Form-6 manifests and Pickup Receipts—required to satisfy Kerala State Pollution Control Board audits.</p>
    `
  },
  {
    id: "ch3",
    num: "03",
    title: "<em>Urban Mining</em>: The Economic Miracle of Material Recovery",
    content: `
      <p>The circular economy treats e-waste as a resource. Circuit boards contain gold, silver, and palladium at concentrations 100x higher than natural mines.</p>
      <p>By recycling in Kochi, we reduce the need for destructive geology. We extract copper, aluminum, and rare earth metals, reintroducing them into the supply chain.</p>
    `
  }
];
---

<WikiPageTemplate
  title="E-Waste Kochi | The Complete Authority Encyclopedia | KSPCB Certified"
  description="The definitive guide on e-waste management in Kochi. Expert analysis of E-Waste Rules 2022, toxic chemistry, and certified disposal protocols."
  badge="The Complete Authority on E-Waste — Kochi 2026"
  heroH1={{ acc: "E-Waste", main: "Encyclopedia", acc2: "Kochi", suffix: "— The Definitive" }}
  heroDesc="The ultimate database mastering e-waste laws, toxic chemistry, material recovery, and certified industrial disposal in Kerala for Infopark and corporate Ernakulam."
  chapters={chapters}
  sidebarLinks={sidebarLinks}
  canonical={ewasteCanonical}
/>
