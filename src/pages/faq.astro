---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { faqs } from '../data/faqs.js';

const pageTitle = "E-Waste & ITAD FAQ | EWaste Kochi";
const pageDesc = "Answers to common questions about e-waste recycling, data destruction, and pickup in Kerala.";

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'FAQ', url: 'https://ewastekochi.com/faq/' },
];

const faqCategories = [
  { name: 'General E-Waste', items: faqs.filter(f => f.category === 'general').slice(0,5) },
  { name: 'ITAD & Data Security', items: faqs.filter(f => f.category === 'itad' || f.category === 'data').slice(0,5) },
  { name: 'Compliance', items: faqs.filter(f => f.category === 'compliance').slice(0,5) },
];
---

<BaseLayout title={pageTitle} description={pageDesc} breadcrumbs={breadcrumbs}>
  <Navbar currentPath="/faq/" />
  <main>
    <section class="section" style="background:var(--bg);padding:80px 0">
      <div class="wrap">
        <nav aria-label="Breadcrumb" style="font-size:0.8rem;color:var(--muted);margin-bottom:20px">
          <a href="/" style="color:var(--green)">Home</a> / FAQ
        </nav>
        <h1 style="font-size:clamp(2.5rem,5vw,4rem);line-height:1.05;margin-bottom:25px;font-weight:800">Frequently Asked <span style="color:var(--green)">Questions</span></h1>
      </div>
    </section>
    <section class="section">
      <div class="wrap">
        {faqCategories.map(cat => (
          <div style="margin-bottom:50px">
            <h2 class="sec-title" style="margin-bottom:25px">{cat.name}</h2>
            <div style="display:grid;gap:16px">
              {cat.items.map(faq => (
                <details style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px">
                  <summary style="font-weight:600;cursor:pointer">{faq.q}</summary>
                  <p style="margin-top:12px;color:var(--muted)">{faq.a}</p>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
