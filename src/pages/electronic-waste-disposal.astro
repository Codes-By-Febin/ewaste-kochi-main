---
// electronic-waste-disposal.astro — High-Intent Landing Page
// GSC targets: "electronic waste disposal", "e waste disposal near me", "where to dispose electronic waste"
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';

const pageTitle = "Electronic Waste Disposal Kochi | Safe E-Waste Disposal | Free Pickup | EWaste Kochi";
const pageDesc = "Safe electronic waste disposal in Kochi. We dispose of all e-waste: computers, phones, TVs, batteries. KSPCB authorized. Free pickup for businesses. Certificate of Disposal provided.";

const whatWeAccept = [
  { category: 'Computers & Laptops', items: 'Desktops, laptops, all-in-ones, monitors, keyboards, mice, cables, accessories' },
  { category: 'Mobile Devices', items: 'Smartphones, tablets, iPads, e-readers, chargers, power banks' },
  { category: 'TVs & Monitors', items: 'CRT, LCD, LED, OLED TVs, computer monitors, projectors' },
  { category: 'Appliances', items: 'Microwaves, refrigerators, washing machines, air conditioners (large items)' },
  { category: 'Peripherals', items: 'Printers, scanners, routers, switches, hard drives, USB devices' },
  { category: 'Batteries', items: 'Li-ion, lead-acid, UPS, EV batteries (handled separately per rules)' },
];

const whyProperDisposal = [
  { icon: '⚡', title: 'Legal Requirement', desc: 'E-Waste Rules 2022 mandate that businesses dispose of e-waste only through authorized recyclers. Non-compliance fines up to ₹1 lakh per ton.' },
  { icon: '🌍', title: 'Environmental Protection', desc: 'E-waste contains hazardous substances like lead, mercury, cadmium. Proper disposal prevents soil & water contamination.' },
  { icon: '🔒', title: 'Data Security', desc: 'Devices often retain sensitive data. We provide NIST data destruction before recycling, protecting you from breaches.' },
  { icon: '💰', title: 'Resource Recovery', desc: 'Electronics contain gold, silver, copper, rare earth metals. Recycling recovers these materials and reduces mining.' },
];

const disposalProcess = [
  { step: '1', title: 'Schedule Pickup', desc: 'Call or WhatsApp to book a pickup. Free for 10+ items.' },
  { step: '2', title: 'Inventory & Collection', desc: 'We inspect, create an inventory manifest, and provide a pickup receipt.' },
  { step: '3', title: 'Data Destruction (if needed)', desc: 'Storage devices are wiped or shredded per your requirement.' },
  { step: '4', title: 'Dismantling & Recycling', desc: 'Devices are dismantled, materials segregated, and sent to certified recycling streams.' },
  { step: '5', title: 'Certificate of Disposal', desc: 'You receive a Certificate of Disposal with details of weight, items, and compliance docs.' },
];

const faqs = [
  { q: 'What is considered electronic waste?', a: 'E-waste includes any electronic device that is no longer needed: computers, laptops, phones, tablets, TVs, monitors, printers, keyboards, mice, cables, routers, switches, hard drives, batteries, small appliances (microwave, kettle), and more. Basically anything with a plug or battery.' },
  { q: 'Is electronic waste disposal free?', a: 'For businesses disposing of 10 or more items, pickup is free. For fewer items, a nominal collection fee may apply. Residential walk-ins to our Thrippunithura facility are always free.' },
  { q: 'What happens to my data during disposal?', a: 'If your devices contain storage (HDD, SSD, phone memory), we strongly recommend NIST-certified data destruction. We offer this as an add-on service and provide a Certificate of Destruction. Without data destruction, devices may be recycled as-is, but we cannot guarantee data security.' },
  { q: 'Do you provide a certificate?', a: 'Yes. Every corporate pickup receives a Certificate of Disposal (or Certificate of Recycling) listing the items, weight, date, and our KSPCB authorization number. This serves as legal proof of compliant disposal.' },
  { q: 'What are the environmental benefits?', a: 'Recycling e-waste keeps toxic heavy metals out of landfills, recovers valuable metals (gold, silver, copper), reduces greenhouse gas emissions from mining, and conserves water and energy. One metric ton of e-waste yields more gold than mining 12 tons of ore.' },
  { q: 'Do you accept broken electronics?', a: 'Yes. We accept both working and non-working devices. Even broken electronics contain valuable components and hazardous materials that need proper handling.' },
  { q: 'Which areas do you serve?', a: 'We collect e-waste across all of Kochi and Ernakulam district: Infopark, Smart City, Kakkanad, Edapally, Vyttila, Palarivattom, Aluva, Angamaly, Thrippunithura, Maradu, Kalamassery, Eloor, and beyond. Same-day pickup often available for urgent jobs.' },
  { q: 'Are you KSPCB authorized?', a: 'Yes. EWaste Kochi is fully authorized by Kerala State Pollution Control Board under E-Waste Rules 2022 and EPR guidelines. We follow all environmental regulations strictly.' },
  { q: 'What about batteries?', a: 'Batteries are handled separately under Battery Waste Management Rules 2022. We accept all battery types: Li-ion (phones/laptops), lead-acid (UPS/inverters), EV batteries. Free bulk collection.' },
  { q: 'How do I prepare for pickup?', a: 'Simply gather devices in one location. No need to dismantle. If you have sensitive data, inform us and we\'ll include data destruction. Our team will handle everything from inspection to loading.' },
];

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Electronic Waste Disposal', url: 'https://ewastekochi.com/electronic-waste-disposal/' },
];

const serviceSchema = {
  '@type': 'RecyclingService',
  name: 'Electronic Waste Disposal Kochi',
  description: pageDesc,
  provider: { '@id': 'https://ewastekochi.com/#organization' },
  areaServed: { '@type': 'City', name: 'Kochi' },
  serviceArea: {
    '@type': 'GeoCircle',
    center: { '@type': 'GeoCoordinates', latitude: 9.9312, longitude: 76.2673 },
    radius: 30000,
  },
};
---

<BaseLayout title={pageTitle} description={pageDesc} schema={serviceSchema} faqs={faqs} breadcrumbs={breadcrumbs}>
  <Navbar currentPath="/electronic-waste-disposal/" />

  <!-- HERO -->
  <section style="padding:80px 0 60px;background:radial-gradient(circle at 70% 30%,rgba(255,152,0,.07),transparent),var(--bg)">
    <div class="wrap">
      <nav aria-label="Breadcrumb" style="font-size:.8rem;color:var(--muted);margin-bottom:20px">
        <a href="/" style="color:var(--green)">Home</a> › Electronic Waste Disposal
      </nav>
      <div class="badge badge-a" style="margin-bottom:20px">♻️ KSPCB Authorized Recycler</div>
      <h1 style="font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.05;margin-bottom:18px;font-weight:800;letter-spacing:-.03em">
        Safe <span style="color:var(--green)">Electronic Waste</span><br/>Disposal in Kochi
      </h1>
      <p style="font-size:1rem;color:var(--text);max-width:620px;line-height:1.7;margin-bottom:35px;font-family:var(--serif);font-style:italic">
        KSPCB authorized e-waste disposal for all electronics. Free pickup for 10+ items. Certificate of Disposal provided. Compliant with E-Waste Rules 2022. Serving Infopark, Kakkanad, and all Ernakulam.
      </p>
      <div style="display:flex;gap:15px;flex-wrap:wrap">
        <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">💬 Book Pickup</a>
        <a href={contact.phoneLink} class="btn btn-primary btn-lg">📞 {contact.phoneDisplay}</a>
        <a href="/contact/" class="btn btn-outline">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- WHAT WE ACCEPT -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">What We Accept</div>
      <h2 class="sec-title"><em>All Types</em> of E-Waste</h2>
      <p class="sec-sub" style="margin-bottom:2rem">We accept virtually any electronic device — working or not.</p>
      <div style="display:grid;gap:20px;max-width:900px;margin:0 auto">
        {whatWeAccept.map(cat => (
          <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;display:flex;flex-direction:column;gap:8px">
            <h3 style="font-size:1.1rem;margin:0;color:var(--text)">{cat.category}</h3>
            <p style="font-size:.9rem;color:var(--muted);margin:0">{cat.items}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY PROPER DISPOSAL -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Why Proper Disposal Matters</div>
      <h2 class="sec-title">More Than Just <em>Recycling</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-top:30px">
        {whyProperDisposal.map(item => (
          <div style="text-align:center;padding:28px;background:var(--card);border-radius:16px;border:1px solid var(--border)">
            <div style="font-size:2.5rem;margin-bottom:16px">{item.icon}</div>
            <h3 style="font-size:1.1rem;margin-bottom:12px;color:var(--text)">{item.title}</h3>
            <p style="font-size:.9rem;color:var(--muted);line-height:1.6">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">Our Process</div>
      <h2 class="sec-title">From Pickup to <em>Certificate</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:30px">
        {disposalProcess.map(step => (
          <div style="background:var(--card);border-radius:16px;padding:28px;text-align:center;border:1px solid var(--border)">
            <div style="font-size:2.5rem;color:var(--green);font-weight:800;margin-bottom:12px">{step.step}</div>
            <h3 style="font-size:1.1rem;margin-bottom:10px">{step.title}</h3>
            <p style="font-size:.9rem;color:var(--muted);line-height:1.6">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPLIANCE BADGES -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Our Credentials</div>
      <h2 class="sec-title">Fully <em>Certified</em> & Compliant</h2>
      <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:30px">
        <div class="badge badge-g" style="font-size:1.1rem;padding:12px 24px">KSPCB Authorized</div>
        <div class="badge badge-b" style="font-size:1.1rem;padding:12px 24px">EPR Compliant</div>
        <div class="badge badge-a" style="font-size:1.1rem;padding:12px 24px">R2 Certified</div>
        <div class="badge badge-r" style="font-size:1.1rem;padding:12px 24px">Zero Landfill</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-alt">
    <div class="wrap">
      <div style="background:linear-gradient(135deg,var(--green),var(--green-dark));color:var(--white);border-radius:20px;padding:50px;text-align:center;margin:60px 0">
        <h2 style="font-size:2rem;margin-bottom:20px">Ready to Dispose of Your Electronic Waste?</h2>
        <p style="font-size:1.1rem;margin-bottom:30px;opacity:0.9">Schedule a free pickup today. Certificate of Disposal included. Serving all of Kochi and Ernakulam.</p>
        <div style="display:flex;gap:15px;flex-wrap:wrap;justify-content:center">
          <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn" style="background:var(--white);color:var(--green);font-weight:800;font-size:1.1rem;padding:16px 32px">💬 WhatsApp Now</a>
          <a href={contact.phoneLink} class="btn" style="background:transparent;border:2px solid var(--white);color:var(--white);font-size:1.1rem;padding:14px 30px">📞 Call Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Questions?</div>
      <h2 class="sec-title">Electronic Waste Disposal — <em>FAQs</em></h2>
      <div style="display:grid;gap:16px;max-width:800px;margin:0 auto">
        {faqs.map((faq, i) => (
          <details style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 20px">
            <summary style="font-weight:600;cursor:pointer;font-size:1.05rem">{faq.q}</summary>
            <p style="margin-top:12px;color:var(--muted);line-height:1.7">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
