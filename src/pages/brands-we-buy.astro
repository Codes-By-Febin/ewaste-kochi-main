---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = 'Brands We Buy | EWaste Kochi Buyback Program';
const description = 'We buy Apple, Dell, HP, Lenovo, Cisco, and all major brands. Get the best buyback prices for your old electronics in Kochi.';
---

<BaseLayout title={title} description={description}>
  <Navbar currentPath="/brands-we-buy/" />
  <section class="py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Brands We Buy</h1>
    <p class="text-xl">Apple, Dell, HP, Lenovo, Cisco - all major brands accepted</p>
  </section>
  <Footer />
</BaseLayout>
