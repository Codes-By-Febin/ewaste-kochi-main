---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';

const pageTitle = "About EWaste Kochi | KSPCB Authorized ITAD & E-Waste Recycler";
const pageDesc = "Kerala's #1 certified ITAD and e-waste recycler. NIST 800-88 data destruction, zero-landfill processing. Founded 2018, 500+ clients served.";

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'About Us', url: 'https://ewastekochi.com/about/' },
];
---

<BaseLayout title={pageTitle} description={pageDesc} breadcrumbs={breadcrumbs}>
  <div id="topbar">
    <div id="ticker">
      <span class="tb-item">♻️ Certified Zero-Landfill Facility — Kochi HQ</span>
      <span class="tb-item">🏭 KSPCB Authorized Recycler #KL/EW/628</span>
      <span class="tb-item">🥇 Kerala's #1 Electronics Recycler since 2018</span>
      <span class="tb-item">📞 24/7 Service — +91-75005-55454</span>
      <!-- Loop -->
      <span class="tb-item">♻️ Certified Zero-Landfill Facility — Kochi HQ</span>
      <span class="tb-item">🏭 KSPCB Authorized Recycler #KL/EW/628</span>
    </div>
  </div>

  <Navbar currentPath="/about/" />

  <main>
    <section class="section" style="background:linear-gradient(135deg, #060809 0%, #0a111a 100%); padding:100px 0; border-bottom: 1px solid var(--border-wiki);">
      <div class="wrap">
        <nav aria-label="Breadcrumb" style="font-size:0.8rem;color:var(--muted);margin-bottom:20px">
          <a href="/" style="color:var(--amber)">Home</a> / About Us
        </nav>
        
        <h1 style="font-size:clamp(2.5rem,5vw,4.45rem);line-height:1;margin-bottom:25px;font-weight:800;letter-spacing:-0.04em">
          Kerala's Most Trusted <span style="color:var(--amber)">E-Waste Authority</span>
        </h1>
        <p style="font-size:1.2rem;color:var(--text);max-width:720px;line-height:1.7;margin-bottom:40px;font-family:var(--serif);font-style:italic">
          Founded in 2018, EWaste Kochi is a KSPCB-authorized recycling and IT asset disposition company based in Thrippunithura. We provide certified, audit-ready solutions for enterprise hardware retirement.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <h2 class="sec-title">The Industrial <em>Authority</em> Certifications</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;margin-top:40px">
          <div style="background:var(--card-wiki);padding:35px;border-radius:20px;border:1px solid var(--border-wiki);border-top:2px solid var(--amber)">
            <div style="font-size:2rem;margin-bottom:15px">🏭</div>
            <h3 style="color:var(--white);margin-bottom:10px">KSPCB Authorized</h3>
            <p style="color:var(--muted);font-size:0.9rem">Authorized under E-Waste Rules 2022 to collect, process and recover electronic waste in Kerala.</p>
            <div style="margin-top:15px;font-size:0.75rem;color:var(--amber);font-weight:700">CERT: #KL/EW/628</div>
          </div>
          <div style="background:var(--card-wiki);padding:35px;border-radius:20px;border:1px solid var(--border-wiki);border-top:2px solid var(--amber)">
            <div style="font-size:2rem;margin-bottom:15px">🔐</div>
            <h3 style="color:var(--white);margin-bottom:10px">NIST 800-88 Purge</h3>
            <p style="color:var(--muted);font-size:0.9rem">Military-grade data destruction for HDD/SSD using logical purging and industrial physical shredding.</p>
            <div style="margin-top:15px;font-size:0.75rem;color:var(--amber);font-weight:700">AUDIT READY</div>
          </div>
          <div style="background:var(--card-wiki);padding:35px;border-radius:20px;border:1px solid var(--border-wiki);border-top:2px solid var(--amber)">
            <div style="font-size:2rem;margin-bottom:15px">⚖️</div>
            <h3 style="color:var(--white);margin-bottom:10px">DPDP Act Shield</h3>
            <p style="color:var(--muted);font-size:0.9rem">Full compliance with India's new data protection laws. Serialized CoD for every asset.</p>
            <div style="margin-top:15px;font-size:0.75rem;color:var(--amber);font-weight:700">100% COMPLIANT</div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="wrap">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center">
          <div>
            <h2 class="sec-title">Our Zero-Landfill <em>Mission</em></h2>
            <p style="color:var(--text);line-height:1.8;margin-top:30px;font-size:1.05rem;font-family:var(--serif)">
              To provide the most secure, transparent, and environmentally sound e-waste management in South India. Our Thrippunithura facility was built to process Kochi's industrial-scale hardware retirement while ensuring every gram of material is reintroduced to the circular economy. We recover gold, silver, copper and aluminum to power Kerala's digital future.
            </p>
          </div>
          <div style="background:var(--card-wiki);padding:40px;border-radius:30px;border:1px solid var(--border-wiki);text-align:center">
             <div style="font-size:3rem;font-weight:900;color:var(--amber);letter-spacing:-0.05em">2,400+ T</div>
             <div style="text-transform:uppercase;font-size:0.8rem;color:var(--muted);letter-spacing:0.15em;margin-bottom:30px">Safe Material Recovery</div>
             <a href="/recycling/" class="btn btn-primary btn-lg" style="background:var(--amber);color:#000">See Tech Encyclopedia →</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .btn:hover { transform:translateY(-2px);box-shadow:0 12px 32px rgba(245,166,35,0.2) }
  .btn-primary { background:var(--amber);color:black }
  .btn-outline { background:transparent;border:1px solid var(--border-wiki);color:var(--text) }
</style>