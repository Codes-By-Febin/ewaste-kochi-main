---
import WikiPageTemplate from '../components/WikiPageTemplate.astro';
import { services } from '../data/services.js';
import { blogs } from '../data/blogs.js';

const recyclingCanonical = 'https://ewastekochi.com/recycling/';
const ogImage = 'https://ewastekochi.com/img/recycling_hero_premium.webp';

// Sidebar links
const sidebarLinks = [
  ...services.filter(s => s.isPillar).map(s => ({ name: s.name, url: `/services/${s.slug}/` })),
  ...blogs.slice(0, 5).map(b => ({ name: b.title, url: `/blog/${b.slug}/` }))
];

const chapters = [
  {
    id: "ch1",
    num: "01",
    title: "What is <em>Electronics Recycling</em> — And Why Kochi Needs It Urgently",
    content: `
      <p>Electronics recycling — formally called e-waste recycling or WEEE (Waste Electrical and Electronic Equipment) processing — is the structured collection, disassembly, material separation, and recovery of discarded electronic and electrical equipment.</p>
      <p>Kochi is Kerala's economic engine. The city hosts <strong>Infopark — home to 400+ IT companies</strong>, Smart City Kochi, and the Cochin Special Economic Zone. This digital economy generates enormous volumes of electronics that have a finite lifespan. Professional recycling is a legal obligation and a data security imperative.</p>
    `
  },
  {
    id: "ch2",
    num: "02",
    title: "The <em>Toxic Chemistry</em> of Electronics — What's Inside Your Old Devices",
    content: `
      <p>Modern electronics contain highly toxic materials if released into the environment. Understanding these is essential for appreciating why certified recycling is critical for Kochi.</p>
      <ul>
        <li><strong>Lead (Pb):</strong> Found in CRT glass (2–8 lbs per monitor).</li>
        <li><strong>Mercury (Hg):</strong> Present in CCFL backlight tubes in older LCDs.</li>
        <li><strong>Cadmium (Cd):</strong> Found in older NiCd rechargeable batteries.</li>
      </ul>
    `
  },
  {
    id: "ch3",
    num: "03",
    title: "<em>Urban Mining</em> — Recovering Gold, Silver & Palladium",
    content: `
      <p>Circuit boards are extraordinarily rich ore bodies. The concentration of gold in high-grade circuit board material can be 10–50x higher than in natural gold ore.</p>
      <p>Professional recycling through EWaste Kochi ensures maximum value is recovered from Kochi's electronics stream while meeting all environmental requirements.</p>
    `
  }
];
---

<WikiPageTemplate
  title="Electronics Recycling Kochi | Certified Zero-Landfill Facility"
  description="Kerala's most complete guide to electronics recycling in Kochi. Industrial shredding, precious metal recovery, and KSPCB compliance."
  badge="KSPCB-Authorized Zero-Landfill Facility — Live 24/7"
  heroH1={{ acc: "Electronics", main: "Recycling", acc2: "Kochi", suffix: "— Done Right" }}
  heroDesc="Kerala's most advanced certified electronics recycling facility. Industrial shredding, precious metal recovery, CRT lead-safe disposal, and zero-landfill compliance."
  chapters={chapters}
  sidebarLinks={sidebarLinks}
  canonical={recyclingCanonical}
  ogImage={ogImage}
/>
