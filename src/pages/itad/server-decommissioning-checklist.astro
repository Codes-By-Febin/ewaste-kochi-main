---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = 'Server Decommissioning Checklist | Data Center Retirement Guide';
const description = 'Complete server decommissioning checklist for data center retirement. ITAD best practices for secure server disposal in Kochi.';
---

<BaseLayout title={title} description={description}>
  <Navbar currentPath="/itad/server-decommissioning-checklist/" />
  <section class="py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Server Decommissioning Checklist</h1>
    <p class="text-xl">Data center retirement and ITAD best practices</p>
  </section>
  <Footer />
</BaseLayout>
