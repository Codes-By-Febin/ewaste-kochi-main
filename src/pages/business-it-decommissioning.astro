---
// business-it-decommissioning.astro — High-Intent B2B Landing Page
// GSC targets: "business IT decommissioning", "office IT clearance", "data centre decommissioning"
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';

const pageTitle = "Business IT Decommissioning Kochi | Office Clearance | Data Centre | EWaste Kochi";
const pageDesc = "Full-service business IT decommissioning in Kochi. Office closures, data centre shutdowns, IT refreshes. Asset recovery, certified data destruction, EPR compliance. Quote-based.";

const servicesOffered = [
  { title: 'Office Closure IT Clearance', desc: 'Complete removal and disposal of all IT equipment when shutting down an office or branch.' },
  { title: 'Data Centre Decommissioning', desc: 'Shutdown of server rooms, network closets, UPS systems. Asset inventory, data destruction, and recycling.' },
  { title: 'IT Refresh Project', desc: 'Retirement of old hardware during hardware upgrade. Secure data migration support and disposal.' },
  { title: 'Business Relocation IT Move', desc: 'Safe packing, transport, and setup or disposal of IT assets during office relocation.' },
  { title: 'Startup Wind-Down', desc: 'For startups closing operations, we handle asset liquidation, data destruction, and compliance closure.' },
];

const process = [
  { step: '1', title: 'Consultation & Survey', desc: 'On-site assessment of equipment volume, types, and data security requirements.' },
  { step: '2', title: 'Inventory & Valuation', desc: 'Detailed asset list with serial numbers, condition grading, and buyback valuation for resalable items.' },
  { step: '3', title: 'Data Destruction', desc: 'NIST/DoD certified data wiping or physical shredding of all storage media. Chain-of-custody logs maintained.' },
  { step: '4', title: ' Asset Recovery', desc: 'We buy back working equipment, reducing your decommissioning cost. Quote provided upfront.' },
  { step: '5', title: 'Recycling & Compliance', desc: 'Non-recoverable assets are recycled per E-Waste Rules 2022. Certificate of Destruction & Recycling provided.' },
];

const whyChooseUs = [
  { icon: '🏢', title: 'Enterprise-Grade', desc: 'We handle large-scale projects with dedicated project managers.' },
  { icon: '📑', title: 'Full Documentation', desc: 'Asset inventories, CoDs, EPR compliance reports — everything for your auditors.' },
  { icon: '🔐', title: 'DPDP & RBI Ready', desc: 'Processes satisfy India\'s data protection and banking regulator requirements.' },
  { icon: '🌱', title: 'Zero Landfill', desc: '100% responsible recycling; nothing goes to landfill.' },
  { icon: '💸', title: 'Asset Recovery', desc: 'We buy back working servers, laptops, network gear, offsetting your costs.' },
  { icon: '⏱️', title: 'Flexible Scheduling', desc: 'After-hours and weekend options to minimize business disruption.' },
];

const industries = [
  'IT & Software Companies', 'Banks & Financial Services', 'Hospitals & Healthcare',
  'Educational Institutions', 'Government Agencies', 'Manufacturing', 'Retail Chains', 'Startups'
];

const faqs = [
  { q: 'What is business IT decommissioning?', a: 'Business IT decommissioning is the end-to-end process of safely retiring IT equipment during office closure, data center shutdown, IT refresh, or relocation. It includes asset inventory, secure data destruction, asset recovery (buyback), and responsible recycling, with full compliance documentation.' },
  { q: 'Why do we need a professional service?', a: 'Improper decommissioning risks data breaches, regulatory fines (DPDP Act, RBI), and environmental violations. Professional service ensures secure data handling, legal compliance, auditable documentation, and maximum value recovery from old assets.' },
  { q: 'What industries do you serve?', a: 'We serve IT companies, banks, hospitals, educational institutions, government agencies, manufacturing, retail, and startups across Kochi and Kerala.' },
  { q: 'Do you buy back the equipment?', a: 'Yes. We assess working equipment and offer buyback prices, which can significantly offset decommissioning costs. Servers, laptops, network gear, and UPS systems have good residual value.' },
  { q: 'What documentation do you provide?', a: 'Complete package: Asset inventory list with serial numbers and condition, Certificate of Destruction for all storage media, Chain of Custody logs, EPR compliance certificate, and final Recycling Report. All documents are available digitally within 48 hours.' },
  { q: 'How long does the process take?', a: 'Timeline depends on project size. Small office (50 devices): 3-5 days. Large data centre (500+ devices): 1-2 weeks. We work after hours/weekends to avoid disrupting your operations.' },
  { q: 'Is the data destruction certified?', a: 'Yes. All data destruction follows NIST 800-88 standards. For storage drives, we offer either cryptographic wiping or physical shredding. You receive a Certificate of Destruction for every device, legally valid for DPDP Act 2023 and RBI audits.' },
  { q: 'Are you authorized under E-Waste Rules?', a: 'Yes. EWaste Kochi is KSPCB authorized and operates under EPR authorization. We ensure 100% compliance with E-Waste (Management) Rules 2022 and provide necessary documentation for your records.' },
];

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Business IT Decommissioning', url: 'https://ewastekochi.com/business-it-decommissioning/' },
];

const serviceSchema = {
  '@type': 'ProfessionalService',
  name: 'Business IT Decommissioning Kochi',
  description: pageDesc,
  provider: { '@id': 'https://ewastekochi.com/#organization' },
  areaServed: { '@type': 'City', name: 'Kochi' },
  offers: {
    '@type': 'Offer',
    price: 'Contact for quote',
    priceCurrency: 'INR',
    description: 'Quote-based depending on scope, equipment volume, and services required',
  },
};
---

<BaseLayout title={pageTitle} description={pageDesc} schema={serviceSchema} faqs={faqs} breadcrumbs={breadcrumbs}>
  <Navbar currentPath="/business-it-decommissioning/" />

  <!-- HERO -->
  <section style="padding:80px 0 60px;background:radial-gradient(circle at 70% 30%,rgba(0,180,255,.07),transparent),var(--bg)">
    <div class="wrap">
      <nav aria-label="Breadcrumb" style="font-size:.8rem;color:var(--muted);margin-bottom:20px">
        <a href="/" style="color:var(--green)">Home</a> › Business IT Decommissioning
      </nav>
      <div class="badge badge-b" style="margin-bottom:20px">🏢 Enterprise IT Decommissioning · DPDP Compliant</div>
      <h1 style="font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.05;margin-bottom:18px;font-weight:800;letter-spacing:-.03em">
        Business IT Decommissioning<br/><span style="font-size:60%;color:var(--muted);font-weight:400">Office Clearance · Data Centre Shutdown · IT Refresh</span>
      </h1>
      <p style="font-size:1rem;color:var(--text);max-width:620px;line-height:1.7;margin-bottom:35px;font-family:var(--serif);font-style:italic">
        Full-service IT decommissioning for businesses in Kochi. Asset recovery, NIST-certified data destruction, EPR compliance. Serving Infopark, Smart City, Kakkanad, and all of Kerala. Get a quote today.
      </p>
      <div style="display:flex;gap:15px;flex-wrap:wrap">
        <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">💬 Request a Quote</a>
        <a href={contact.phoneLink} class="btn btn-primary btn-lg">📞 Call Now</a>
        <a href="/itad-kochi/" class="btn btn-outline">Our ITAD Services →</a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">Our Services</div>
      <h2 class="sec-title">Comprehensive <em>IT Decommissioning</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:30px">
        {servicesOffered.map(s => (
          <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:24px">
            <h3 style="font-size:1.1rem;margin-bottom:10px;color:var(--text)">{s.title}</h3>
            <p style="font-size:.9rem;color:var(--muted);line-height:1.6">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Why EWaste Kochi</div>
      <h2 class="sec-title">Why Businesses Trust Us for <em>IT Decommissioning</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;margin-top:30px">
        {whyChooseUs.map(item => (
          <div style="display:flex;align-items:flex-start;gap:12px;background:var(--card);padding:20px;border-radius:12px;border:1px solid var(--border)">
            <div style="font-size:1.5rem">{item.icon}</div>
            <div>
              <h4 style="font-size:1rem;margin-bottom:6px;color:var(--text)">{item.title}</h4>
              <p style="font-size:.85rem;color:var(--muted);line-height:1.6">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section-alt">
    <div class="wrap">
      <div class="sec-eyebrow">Our Process</div>
      <h2 class="sec-title">From Assessment to <em>Certificate</em></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:30px">
        {process.map(step => (
          <div style="text-align:center;background:var(--card);border-radius:16px;padding:28px;border:1px solid var(--border)">
            <div style="font-size:2.5rem;color:var(--blue);font-weight:800;margin-bottom:12px">{step.step}</div>
            <h3 style="font-size:1.1rem;margin-bottom:10px">{step.title}</h3>
            <p style="font-size:.9rem;color:var(--muted);line-height:1.6">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Industries We Serve</div>
      <h2 class="sec-title">Trusted by <em>All Sectors</em></h2>
      <p style="max-width:700px;margin-bottom:24px">
        From Infopark IT companies to banks, hospitals, government offices, and large corporates — we handle decommissioning projects of any scale.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center">
        {industries.map(ind => (
          <span class="badge" style="font-size:1rem;padding:10px 18px">{ind}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-alt">
    <div class="wrap">
      <div style="background:linear-gradient(135deg,var(--blue),#1e40af);color:var(--white);border-radius:20px;padding:50px;text-align:center;margin:60px 0">
        <h2 style="font-size:2rem;margin-bottom:20px">Planning an IT Decommissioning Project?</h2>
        <p style="font-size:1.1rem;margin-bottom:30px;opacity:0.9">Contact us for a free site survey and quote. Full documentation, asset recovery, and DPDP compliance included.</p>
        <div style="display:flex;gap:15px;flex-wrap:wrap;justify-content:center">
          <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn" style="background:var(--white);color:var(--blue);font-weight:800;font-size:1.1rem;padding:16px 32px">💬 WhatsApp Us</a>
          <a href={contact.phoneLink} class="btn" style="background:transparent;border:2px solid var(--white);color:var(--white);font-size:1.1rem;padding:14px 30px">📞 Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="wrap">
      <div class="sec-eyebrow">Questions?</div>
      <h2 class="sec-title">Business IT Decommissioning — <em>FAQs</em></h2>
      <div style="display:grid;gap:16px;max-width:800px;margin:0 auto">
        {faqs.map((faq, i) => (
          <details style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 20px">
            <summary style="font-weight:600;cursor:pointer;font-size:1.05rem">{faq.q}</summary>
            <p style="margin-top:12px;color:var(--muted);line-height:1.7">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
