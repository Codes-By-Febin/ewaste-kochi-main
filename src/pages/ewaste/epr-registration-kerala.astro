---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = 'EPR Registration Kerala | E-Waste Producer Responsibility Guide';
const description = 'Complete guide to EPR registration in Kerala. How to file EPR for importers, manufacturers, and brand owners under E-Waste Rules 2022.';
---

<BaseLayout title={title} description={description}>
  <Navbar currentPath="/ewaste/epr-registration-kerala/" />
  <section class="py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">EPR Registration Kerala</h1>
    <p class="text-xl">Complete guide to Extended Producer Responsibility in Kerala</p>
  </section>
  <Footer />
</BaseLayout>
