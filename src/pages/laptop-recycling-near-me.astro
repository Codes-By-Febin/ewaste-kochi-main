---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import ServiceCard from '../components/ServiceCard.astro';

const meta = {
  title: 'Laptop Recycling Near Me | Secure Data Destruction & Pickup',
  description: 'Professional laptop recycling with secure data destruction, battery handling, and local pickup options. Certified e-waste disposal services near you.',
  keywords: ['laptop recycling near me', 'laptop recycling', 'secure data destruction', 'e-waste recycling', 'battery recycling', 'local pickup'],
  canonical: 'https://ewaste-kochi.com/laptop-recycling-near-me'
};
---

<Layout meta={meta}>
  <section class="hero">
    <div class="hero-content">
      <h1>Laptop Recycling Near Me</h1>
      <p>Professional, secure, and certified laptop recycling services with local pickup options. We ensure your data is completely destroyed and your battery is handled safely.</p>
      <div class="cta-buttons">
        <a href="#services" class="btn btn-primary">Get a Quote</a>
        <a href="#contact" class="btn btn-secondary">Schedule Pickup</a>
      </div>
    </div>
  </section>

  <section id="laptop-process" class="process-section">
    <div class="container">
      <h2>Our Laptop Recycling Process</h2>
      <div class="process-steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Collection & Assessment</h3>
          <p>We collect your laptop locally and perform a comprehensive assessment of its condition, specifications, and reusable components.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Data Destruction</h3>
          <p>Professional data wiping using military-grade standards. Physical destruction of storage devices when necessary to ensure complete data security.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Component Separation</h3>
          <p>Careful disassembly to separate valuable materials: precious metals, plastics, circuit boards, and glass for proper recycling.</p>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <h3>Material Recovery</h3>
          <p>Advanced processing to recover reusable materials and ensure environmentally responsible disposal of hazardous components.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="data-security" class="security-section">
    <div class="container">
      <h2>Data Security & Privacy</h2>
      <div class="security-features">
        <div class="feature-card">
          <h3>Certified Data Destruction</h3>
          <p>We follow NIST 800-88 guidelines for media sanitization, ensuring your personal and business data is permanently unrecoverable.</p>
        </div>
        <div class="feature-card">
          <h3>Chain of Custody Documentation</h3>
          <p>Complete tracking from pickup through processing, with detailed logs for your compliance and audit requirements.</p>
        </div>
        <div class="feature-card">
          <h3>On-Site Data Wiping</h3>
          <p>Available for enterprise clients who require data destruction to be performed at their location under supervision.</p>
        </div>
        <div class="feature-card">
          <h3>Certificate of Destruction</h3>
          <p>Receive a detailed certificate documenting the destruction process for each device, including serial numbers and timestamps.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="battery-handling" class="battery-section">
    <div class="container">
      <h2>Battery Handling & Safety</h2>
      <div class="battery-content">
        <div class="battery-info">
          <h3>Why Professional Battery Handling Matters</h3>
          <p>Laptop batteries contain lithium-ion cells that can be hazardous if not handled properly. We follow strict safety protocols to prevent fires, explosions, and environmental contamination.</p>
        </div>
        <div class="battery-process">
          <h3>Our Battery Disposal Process:</h3>
          <ul>
            <li>Initial safety inspection and testing</li>
            <li>Careful removal by trained technicians with proper PPE</li>
            <li>Transportation to certified battery recycling facilities</li>
            <li>Material recovery including lithium, cobalt, and nickel</li>
            <li>Proper disposal of damaged or non-recyclable batteries</li>
          </ul>
        </div>
        <div class="safety-certifications">
          <h3>Safety Certifications</h3>
          <p>Our facility complies with DOT, EPA, and OSHA regulations for handling lithium-ion batteries and other hazardous materials.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="pickup-services" class="pickup-section">
    <div class="container">
      <h2>Local Pickup Options</h2>
      <div class="pickup-options">
        <div class="pickup-option">
          <h3>Residential Pickup</h3>
          <p>Schedule a convenient pickup time for your home. We serve all major areas with no minimum quantity requirements.</p>
          <ul>
            <li>Free consultation and quote</li>
            <li>Flexible scheduling including weekends</li>
            <li>Same-day pickup available in most areas</li>
            <li>Service for single laptops to bulk collections</li>
          </ul>
        </div>
        <div class="pickup-option">
          <h3>Business/Office Pickup</h3>
          <p>Corporate e-waste management solutions with dedicated account management and customized pickup schedules.</p>
          <ul>
            <li>Large volume discount programs</li>
            <li>On-site data destruction services</li>
            <li>Compliance reporting and documentation</li>
            <li>Scheduled recurring pickups</li>
          </ul>
        </div>
        <div class="pickup-option">
          <h3>Drop-Off Locations</h3>
          <p>Visit our certified e-waste recycling centers for self-drop off services. Secure kiosks available 24/7 at select locations.</p>
          <ul>
            <li>Find locations near you</li>
            <li>Extended hours operation</li>
            <li>Immediate processing and documentation</li>
            <li>Competitive pricing per unit</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="service-categories" class="categories-section">
    <div class="container">
      <h2>Additional Services</h2>
      <div class="service-cards">
        <ServiceCard
          title="Desktop Computer Recycling"
          description="Complete recycling service for desktop towers, monitors, keyboards, and accessories."
          icon="desktop"
        />
        <ServiceCard
          title="Tablet & Phone Recycling"
          description="Secure disposal of tablets, smartphones, and mobile devices with data destruction."
          icon="tablet"
        />
        <ServiceCard
          title="Hard Drive Destruction"
          description="Physical destruction of hard drives and solid-state drives for maximum security."
          icon="shield"
        />
        <ServiceCard
          title="Printer & Copier Recycling"
          description="Environmentally responsible disposal of office equipment and imaging devices."
          icon="printer"
        />
      </div>
    </div>
  </section>

  <section id="contact" class="contact-section">
    <div class="container">
      <h2>Ready to Recycle Your Laptop?</h2>
      <p>Contact us today to schedule your laptop recycling with local pickup. Get a competitive quote and certificate of destruction.</p>
      <ContactForm />
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #3a7bd5 100%);
    color: white;
    padding: 120px 0;
    text-align: center;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .hero-content p {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .process-section,
  .security-section,
  .battery-section,
  .pickup-section,
  .categories-section,
  .contact-section {
    padding: 80px 0;
  }

  .process-section h2,
  .security-section h2,
  .battery-section h2,
  .pickup-section h2,
  .categories-section h2,
  .contact-section h2 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 3rem;
    color: #1e3c72;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .step {
    background: #f8f9fa;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #2a5298;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .step:hover {
    transform: translateY(-5px);
  }

  .step-number {
    display: inline-block;
    width: 50px;
    height: 50px;
    background: #2a5298;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .step h3 {
    margin-bottom: 1rem;
    color: #1e3c72;
  }

  .security-features,
  .battery-process,
  .pickup-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card,
  .safety-certifications {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .feature-card h3,
  .safety-certifications h3 {
    color: #1e3c72;
    margin-bottom: 1rem;
  }

  .battery-process ul {
    list-style: none;
    padding: 0;
  }

  .battery-process li {
    padding: 0.5rem 0;
    position: relative;
    padding-left: 1.5rem;
  }

  .battery-process li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2a5298;
    font-weight: bold;
  }

  .pickup-option {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .pickup-option h3 {
    color: #1e3c72;
    margin-bottom: 1rem;
  }

  .categories-section {
    background: #f8f9fa;
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .contact-section {
    background: #1e3c72;
    color: white;
  }

  .contact-section h2 {
    color: white;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }

    .process-steps,
    .security-features,
    .battery-process,
    .pickup-options {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
