---
import BaseLayout from '../layouts/BaseLayout.astro';
const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "IT Asset Disposition Services",
  "description": "Professional ITAD services for businesses in Kochi",
  "provider": { "@type": "LocalBusiness", "name": "EWaste Kochi" }
};
---

<BaseLayout 
  title="IT Asset Disposition Kochi - Corporate IT Disposal"
  description="Professional ITAD services for Kochi businesses. Secure data destruction, asset recovery, compliance documentation."
  schema={schema}
>
  <h1>IT Asset Disposition (ITAD) Services</h1>
  <p>Complete end-to-end IT asset disposal for businesses in Kochi.</p>
  
  <h2>Our ITAD Process</h2>
  <ol>
    <li>Asset inventory and valuation</li>
    <li>Secure data destruction</li>
    <li>Asset recovery and resale</li>
    <li>Environmental disposal</li>
    <li>Compliance documentation</li>
  </ol>
  
  <h2>Services Include</h2>
  <ul>
    <li>Server and data center disposal</li>
    <li>Network equipment recycling</li>
    <li>Storage media destruction</li>
    <li>Asset buyback programs</li>
  </ul>
  
  <a href="/contact/" class="cta">Get ITAD Quote</a>
</BaseLayout>
