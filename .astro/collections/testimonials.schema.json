{
  "$ref": "#/definitions/testimonials",
  "definitions": {
    "testimonials": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "default": 5
        },
        "avatar": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "service_type": {
          "type": "string"
        },
        "verified": {
          "type": "boolean",
          "default": true
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "order": {
          "type": "number",
          "default": 0
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "content"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}